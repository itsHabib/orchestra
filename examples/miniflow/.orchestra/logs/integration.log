{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016VkYFJabE3xqL7vYrqgZkW","type":"tool_result","content":"     1→package executor\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"testing\"\n     6→\t\"time\"\n     7→\n     8→\t\"miniflow/internal/model\"\n     9→)\n    10→\n    11→// mockStore is an in-memory implementation of RunStore for testing.\n    12→type mockStore struct {\n    13→\truns         map[string]*model.WorkflowRun\n    14→\tworkflows    map[string]*model.Workflow\n    15→\tactivityRuns map[string][]model.ActivityRun // keyed by workflow run ID\n    16→\tevents       []model.Event\n    17→}\n    18→\n    19→func newMockStore() *mockStore {\n    20→\treturn &mockStore{\n    21→\t\truns:         make(map[string]*model.WorkflowRun),\n    22→\t\tworkflows:    make(map[string]*model.Workflow),\n    23→\t\tactivityRuns: make(map[string][]model.ActivityRun),\n    24→\t}\n    25→}\n    26→\n    27→func (m *mockStore) GetRun(id string) (*model.WorkflowRun, error) {\n    28→\tr, ok := m.runs[id]\n    29→\tif !ok {\n    30→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n    31→\t}\n    32→\t// Return a copy so mutations in the executor are only persisted via UpdateRun.\n    33→\tcp := *r\n    34→\treturn &cp, nil\n    35→}\n    36→\n    37→func (m *mockStore) UpdateRun(r *model.WorkflowRun) error {\n    38→\tcp := *r\n    39→\tm.runs[r.ID] = &cp\n    40→\treturn nil\n    41→}\n    42→\n    43→func (m *mockStore) GetWorkflow(id string) (*model.Workflow, error) {\n    44→\tw, ok := m.workflows[id]\n    45→\tif !ok {\n    46→\t\treturn nil, fmt.Errorf(\"workflow %q not found\", id)\n    47→\t}\n    48→\treturn w, nil\n    49→}\n    50→\n    51→func (m *mockStore) CreateActivityRun(ar *model.ActivityRun) error {\n    52→\tcp := *ar\n    53→\tm.activityRuns[ar.WorkflowRunID] = append(m.activityRuns[ar.WorkflowRunID], cp)\n    54→\treturn nil\n    55→}\n    56→\n    57→func (m *mockStore) GetActivityRunsByRunID(runID string) ([]model.ActivityRun, error) {\n    58→\treturn m.activityRuns[runID], nil\n    59→}\n    60→\n    61→func (m *mockStore) AppendEvent(e *model.Event) error {\n    62→\tm.events = append(m.events, *e)\n    63→\treturn nil\n    64→}\n    65→\n    66→func (m *mockStore) ListRuns(status string, limit int) ([]model.WorkflowRun, error) {\n    67→\tvar result []model.WorkflowRun\n    68→\tfor _, r := range m.runs {\n    69→\t\tif r.Status == status {\n    70→\t\t\tresult = append(result, *r)\n    71→\t\t\tif len(result) >= limit {\n    72→\t\t\t\tbreak\n    73→\t\t\t}\n    74→\t\t}\n    75→\t}\n    76→\treturn result, nil\n    77→}\n    78→\n    79→// --- helpers ---\n    80→\n    81→func twoStepWorkflow() *model.Workflow {\n    82→\treturn &model.Workflow{\n    83→\t\tID:   \"wf-1\",\n    84→\t\tName: \"two-step\",\n    85→\t\tDefinition: model.WorkflowDefinition{\n    86→\t\t\tActivities: []model.ActivitySpec{\n    87→\t\t\t\t{Name: \"step-a\", Type: \"http\", InputExpr: \"$.input\", TimeoutSeconds: 30, MaxRetries: 1},\n    88→\t\t\t\t{Name: \"step-b\", Type: \"http\", InputExpr: \"$.steps[0].output\", TimeoutSeconds: 30, MaxRetries: 0},\n    89→\t\t\t},\n    90→\t\t},\n    91→\t\tCreatedAt: time.Now().UTC(),\n    92→\t}\n    93→}\n    94→\n    95→func pendingRun() *model.WorkflowRun {\n    96→\treturn &model.WorkflowRun{\n    97→\t\tID:          \"run-1\",\n    98→\t\tWorkflowID:  \"wf-1\",\n    99→\t\tStatus:      model.StatusRunning,\n   100→\t\tInput:       `{\"url\":\"https://example.com\"}`,\n   101→\t\tCurrentStep: 0,\n   102→\t\tCreatedAt:   time.Now().UTC(),\n   103→\t}\n   104→}\n   105→\n   106→// --- tests ---\n   107→\n   108→func TestAdvanceRun_SchedulesFirstActivity(t *testing.T) {\n   109→\tstore := newMockStore()\n   110→\tstore.workflows[\"wf-1\"] = twoStepWorkflow()\n   111→\tstore.runs[\"run-1\"] = pendingRun()\n   112→\n   113→\texec := NewExecutor(store)\n   114→\tif err := exec.AdvanceRun(\"run-1\"); err != nil {\n   115→\t\tt.Fatalf(\"AdvanceRun: %v\", err)\n   116→\t}\n   117→\n   118→\tars := store.activityRuns[\"run-1\"]\n   119→\tif len(ars) != 1 {\n   120→\t\tt.Fatalf(\"expected 1 activity run, got %d\", len(ars))\n   121→\t}\n   122→\tar := ars[0]\n   123→\tif ar.ActivityName != \"step-a\" {\n   124→\t\tt.Errorf(\"expected activity name %q, got %q\", \"step-a\", ar.ActivityName)\n   125→\t}\n   126→\tif ar.StepIndex != 0 {\n   127→\t\tt.Errorf(\"expected step index 0, got %d\", ar.StepIndex)\n   128→\t}\n   129→\tif ar.Status != model.StatusPending {\n   130→\t\tt.Errorf(\"expected status %q, got %q\", model.StatusPending, ar.Status)\n   131→\t}\n   132→\tif ar.Input != `{\"url\":\"https://example.com\"}` {\n   133→\t\tt.Errorf(\"expected input to be run input, got %q\", ar.Input)\n   134→\t}\n   135→\n   136→\t// Should have emitted an activity_scheduled event.\n   137→\tfound := false\n   138→\tfor _, ev := range store.events {\n   139→\t\tif ev.EventType == model.EventActivityScheduled {\n   140→\t\t\tfound = true\n   141→\t\t}\n   142→\t}\n   143→\tif !found {\n   144→\t\tt.Error(\"expected activity_scheduled event\")\n   145→\t}\n   146→}\n   147→\n   148→func TestAdvanceRun_AdvancesToNextStep(t *testing.T) {\n   149→\tstore := newMockStore()\n   150→\tstore.workflows[\"wf-1\"] = twoStepWorkflow()\n   151→\trun := pendingRun()\n   152→\trun.CurrentStep = 0\n   153→\tstore.runs[\"run-1\"] = run\n   154→\n   155→\t// Simulate first activity completed.\n   156→\tstore.activityRuns[\"run-1\"] = []model.ActivityRun{\n   157→\t\t{\n   158→\t\t\tID:            \"ar-1\",\n   159→\t\t\tWorkflowRunID: \"run-1\",\n   160→\t\t\tActivityName:  \"step-a\",\n   161→\t\t\tStepIndex:     0,\n   162→\t\t\tStatus:        model.StatusCompleted,\n   163→\t\t\tInput:         `{\"url\":\"https://example.com\"}`,\n   164→\t\t\tOutput:        `{\"body\":\"hello\"}`,\n   165→\t\t\tAttempts:      1,\n   166→\t\t},\n   167→\t}\n   168→\n   169→\texec := NewExecutor(store)\n   170→\tif err := exec.AdvanceRun(\"run-1\"); err != nil {\n   171→\t\tt.Fatalf(\"AdvanceRun: %v\", err)\n   172→\t}\n   173→\n   174→\t// Run should have advanced to step 1.\n   175→\tupdatedRun := store.runs[\"run-1\"]\n   176→\tif updatedRun.CurrentStep != 1 {\n   177→\t\tt.Errorf(\"expected current_step=1, got %d\", updatedRun.CurrentStep)\n   178→\t}\n   179→\n   180→\t// Second activity should be scheduled.\n   181→\tars := store.activityRuns[\"run-1\"]\n   182→\tif len(ars) != 2 {\n   183→\t\tt.Fatalf(\"expected 2 activity runs, got %d\", len(ars))\n   184→\t}\n   185→\tar := ars[1]\n   186→\tif ar.ActivityName != \"step-b\" {\n   187→\t\tt.Errorf(\"expected activity name %q, got %q\", \"step-b\", ar.ActivityName)\n   188→\t}\n   189→\tif ar.StepIndex != 1 {\n   190→\t\tt.Errorf(\"expected step index 1, got %d\", ar.StepIndex)\n   191→\t}\n   192→\t// Input should be resolved from $.steps[0].output.\n   193→\tif ar.Input != `{\"body\":\"hello\"}` {\n   194→\t\tt.Errorf(\"expected input from step 0 output, got %q\", ar.Input)\n   195→\t}\n   196→}\n   197→\n   198→func TestAdvanceRun_CompletesWorkflow(t *testing.T) {\n   199→\tstore := newMockStore()\n   200→\tstore.workflows[\"wf-1\"] = twoStepWorkflow()\n   201→\trun := pendingRun()\n   202→\trun.CurrentStep = 1\n   203→\tstore.runs[\"run-1\"] = run\n   204→\n   205→\t// Both activities completed.\n   206→\tstore.activityRuns[\"run-1\"] = []model.ActivityRun{\n   207→\t\t{\n   208→\t\t\tID:            \"ar-1\",\n   209→\t\t\tWorkflowRunID: \"run-1\",\n   210→\t\t\tActivityName:  \"step-a\",\n   211→\t\t\tStepIndex:     0,\n   212→\t\t\tStatus:        model.StatusCompleted,\n   213→\t\t\tOutput:        `{\"body\":\"hello\"}`,\n   214→\t\t\tAttempts:      1,\n   215→\t\t},\n   216→\t\t{\n   217→\t\t\tID:            \"ar-2\",\n   218→\t\t\tWorkflowRunID: \"run-1\",\n   219→\t\t\tActivityName:  \"step-b\",\n   220→\t\t\tStepIndex:     1,\n   221→\t\t\tStatus:        model.StatusCompleted,\n   222→\t\t\tOutput:        `{\"result\":\"done\"}`,\n   223→\t\t\tAttempts:      1,\n   224→\t\t},\n   225→\t}\n   226→\n   227→\texec := NewExecutor(store)\n   228→\tif err := exec.AdvanceRun(\"run-1\"); err != nil {\n   229→\t\tt.Fatalf(\"AdvanceRun: %v\", err)\n   230→\t}\n   231→\n   232→\tupdatedRun := store.runs[\"run-1\"]\n   233→\tif updatedRun.Status != model.StatusCompleted {\n   234→\t\tt.Errorf(\"expected status %q, got %q\", model.StatusCompleted, updatedRun.Status)\n   235→\t}\n   236→\tif updatedRun.Output != `{\"result\":\"done\"}` {\n   237→\t\tt.Errorf(\"expected output from last activity, got %q\", updatedRun.Output)\n   238→\t}\n   239→\tif updatedRun.CompletedAt == nil {\n   240→\t\tt.Error(\"expected completed_at to be set\")\n   241→\t}\n   242→\n   243→\t// Should have workflow_completed event.\n   244→\tfound := false\n   245→\tfor _, ev := range store.events {\n   246→\t\tif ev.EventType == model.EventWorkflowCompleted {\n   247→\t\t\tfound = true\n   248→\t\t}\n   249→\t}\n   250→\tif !found {\n   251→\t\tt.Error(\"expected workflow_completed event\")\n   252→\t}\n   253→}\n   254→\n   255→func TestAdvanceRun_FailsWorkflow(t *testing.T) {\n   256→\tstore := newMockStore()\n   257→\tstore.workflows[\"wf-1\"] = twoStepWorkflow()\n   258→\trun := pendingRun()\n   259→\trun.CurrentStep = 0\n   260→\tstore.runs[\"run-1\"] = run\n   261→\n   262→\t// First activity failed with max retries exhausted (MaxRetries=1, Attempts=2).\n   263→\tstore.activityRuns[\"run-1\"] = []model.ActivityRun{\n   264→\t\t{\n   265→\t\t\tID:            \"ar-1\",\n   266→\t\t\tWorkflowRunID: \"run-1\",\n   267→\t\t\tActivityName:  \"step-a\",\n   268→\t\t\tStepIndex:     0,\n   269→\t\t\tStatus:        model.StatusFailed,\n   270→\t\t\tAttempts:      2,\n   271→\t\t\tMaxRetries:    1,\n   272→\t\t},\n   273→\t}\n   274→\n   275→\texec := NewExecutor(store)\n   276→\tif err := exec.AdvanceRun(\"run-1\"); err != nil {\n   277→\t\tt.Fatalf(\"AdvanceRun: %v\", err)\n   278→\t}\n   279→\n   280→\tupdatedRun := store.runs[\"run-1\"]\n   281→\tif updatedRun.Status != model.StatusFailed {\n   282→\t\tt.Errorf(\"expected status %q, got %q\", model.StatusFailed, updatedRun.Status)\n   283→\t}\n   284→\tif updatedRun.CompletedAt == nil {\n   285→\t\tt.Error(\"expected completed_at to be set\")\n   286→\t}\n   287→\n   288→\t// Should have workflow_failed event.\n   289→\tfound := false\n   290→\tfor _, ev := range store.events {\n   291→\t\tif ev.EventType == model.EventWorkflowFailed {\n   292→\t\t\tfound = true\n   293→\t\t}\n   294→\t}\n   295→\tif !found {\n   296→\t\tt.Error(\"expected workflow_failed event\")\n   297→\t}\n   298→}\n   299→\n   300→func TestResolveInputExpr(t *testing.T) {\n   301→\trun := &model.WorkflowRun{\n   302→\t\tInput: `{\"key\":\"value\"}`,\n   303→\t}\n   304→\tactivityRuns := []model.ActivityRun{\n   305→\t\t{StepIndex: 0, Output: `{\"out0\":\"a\"}`},\n   306→\t\t{StepIndex: 1, Output: `{\"out1\":\"b\"}`},\n   307→\t}\n   308→\n   309→\ttests := []struct {\n   310→\t\tname string\n   311→\t\texpr string\n   312→\t\twant string\n   313→\t}{\n   314→\t\t{\"dollar input\", \"$.input\", `{\"key\":\"value\"}`},\n   315→\t\t{\"step 0 output\", \"$.steps[0].output\", `{\"out0\":\"a\"}`},\n   316→\t\t{\"step 1 output\", \"$.steps[1].output\", `{\"out1\":\"b\"}`},\n   317→\t\t{\"missing step\", \"$.steps[99].output\", \"\"},\n   318→\t\t{\"empty expr\", \"\", `{\"key\":\"value\"}`},\n   319→\t\t{\"unknown expr\", \"something.else\", `{\"key\":\"value\"}`},\n   320→\t}\n   321→\n   322→\tfor _, tt := range tests {\n   323→\t\tt.Run(tt.name, func(t *testing.T) {\n   324→\t\t\tgot := resolveInputExpr(tt.expr, run, activityRuns)\n   325→\t\t\tif got != tt.want {\n   326→\t\t\t\tt.Errorf(\"resolveInputExpr(%q) = %q, want %q\", tt.expr, got, tt.want)\n   327→\t\t\t}\n   328→\t\t})\n   329→\t}\n   330→}\n   331→\n   332→func TestStartRun(t *testing.T) {\n   333→\tstore := newMockStore()\n   334→\tstore.workflows[\"wf-1\"] = twoStepWorkflow()\n   335→\trun := &model.WorkflowRun{\n   336→\t\tID:          \"run-1\",\n   337→\t\tWorkflowID:  \"wf-1\",\n   338→\t\tStatus:      model.StatusPending,\n   339→\t\tInput:       `{\"url\":\"https://example.com\"}`,\n   340→\t\tCurrentStep: 0,\n   341→\t\tCreatedAt:   time.Now().UTC(),\n   342→\t}\n   343→\tstore.runs[\"run-1\"] = run\n   344→\n   345→\texec := NewExecutor(store)\n   346→\tif err := exec.StartRun(\"run-1\"); err != nil {\n   347→\t\tt.Fatalf(\"StartRun: %v\", err)\n   348→\t}\n   349→\n   350→\tupdatedRun := store.runs[\"run-1\"]\n   351→\tif updatedRun.Status != model.StatusRunning {\n   352→\t\tt.Errorf(\"expected status %q, got %q\", model.StatusRunning, updatedRun.Status)\n   353→\t}\n   354→\tif updatedRun.StartedAt == nil {\n   355→\t\tt.Error(\"expected started_at to be set\")\n   356→\t}\n   357→\n   358→\t// Should have workflow_started event.\n   359→\tfoundStarted := false\n   360→\tfor _, ev := range store.events {\n   361→\t\tif ev.EventType == model.EventWorkflowStarted {\n   362→\t\t\tfoundStarted = true\n   363→\t\t}\n   364→\t}\n   365→\tif !foundStarted {\n   366→\t\tt.Error(\"expected workflow_started event\")\n   367→\t}\n   368→\n   369→\t// StartRun should also call AdvanceRun, scheduling the first activity.\n   370→\tars := store.activityRuns[\"run-1\"]\n   371→\tif len(ars) != 1 {\n   372→\t\tt.Fatalf(\"expected 1 activity run after StartRun, got %d\", len(ars))\n   373→\t}\n   374→\tif ars[0].ActivityName != \"step-a\" {\n   375→\t\tt.Errorf(\"expected first activity %q, got %q\", \"step-a\", ars[0].ActivityName)\n   376→\t}\n   377→}\n   378→"}]},"parent_tool_use_id":"toolu_01NHF3R5g7kdFioUm6bPGqQp","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"095293f4-f746-43bc-a24c-52f732b60b92"}
