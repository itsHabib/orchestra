{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XebnDn3zDTx9piJdVCmDhu","type":"tool_result","content":"     1→package executor\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"regexp\"\n     6→\t\"strconv\"\n     7→\t\"time\"\n     8→\n     9→\t\"miniflow/internal/model\"\n    10→\n    11→\t\"github.com/google/uuid\"\n    12→)\n    13→\n    14→// RunStore defines the storage interface the executor depends on.\n    15→// The real SQLite store (built concurrently) will satisfy this interface.\n    16→type RunStore interface {\n    17→\tGetRun(id string) (*model.WorkflowRun, error)\n    18→\tUpdateRun(r *model.WorkflowRun) error\n    19→\tGetWorkflow(id string) (*model.Workflow, error)\n    20→\tCreateActivityRun(ar *model.ActivityRun) error\n    21→\tGetActivityRunsByRunID(runID string) ([]model.ActivityRun, error)\n    22→\tAppendEvent(e *model.Event) error\n    23→\tListRuns(status string, limit int) ([]model.WorkflowRun, error)\n    24→}\n    25→\n    26→// Executor drives workflow runs forward by inspecting state and scheduling\n    27→// the next activity or completing/failing the run.\n    28→type Executor struct {\n    29→\tstore RunStore\n    30→}\n    31→\n    32→// NewExecutor returns an Executor backed by the given store.\n    33→func NewExecutor(store RunStore) *Executor {\n    34→\treturn &Executor{store: store}\n    35→}\n    36→\n    37→// StartRun transitions a pending run to running, emits a workflow_started\n    38→// event, and calls AdvanceRun to kick off the first activity.\n    39→func (e *Executor) StartRun(runID string) error {\n    40→\trun, err := e.store.GetRun(runID)\n    41→\tif err != nil {\n    42→\t\treturn fmt.Errorf(\"start run: get run: %w\", err)\n    43→\t}\n    44→\n    45→\tnow := time.Now().UTC()\n    46→\trun.Status = model.StatusRunning\n    47→\trun.StartedAt = &now\n    48→\n    49→\tif err := e.store.UpdateRun(run); err != nil {\n    50→\t\treturn fmt.Errorf(\"start run: update run: %w\", err)\n    51→\t}\n    52→\n    53→\tif err := e.store.AppendEvent(&model.Event{\n    54→\t\tWorkflowRunID: run.ID,\n    55→\t\tEventType:     model.EventWorkflowStarted,\n    56→\t\tCreatedAt:     now,\n    57→\t}); err != nil {\n    58→\t\treturn fmt.Errorf(\"start run: append event: %w\", err)\n    59→\t}\n    60→\n    61→\treturn e.AdvanceRun(runID)\n    62→}\n    63→\n    64→// CancelRun marks a run as cancelled and emits a workflow_cancelled event.\n    65→func (e *Executor) CancelRun(runID string) error {\n    66→\trun, err := e.store.GetRun(runID)\n    67→\tif err != nil {\n    68→\t\treturn fmt.Errorf(\"cancel run: get run: %w\", err)\n    69→\t}\n    70→\n    71→\tnow := time.Now().UTC()\n    72→\trun.Status = model.StatusCancelled\n    73→\trun.CompletedAt = &now\n    74→\n    75→\tif err := e.store.UpdateRun(run); err != nil {\n    76→\t\treturn fmt.Errorf(\"cancel run: update run: %w\", err)\n    77→\t}\n    78→\n    79→\treturn e.store.AppendEvent(&model.Event{\n    80→\t\tWorkflowRunID: run.ID,\n    81→\t\tEventType:     model.EventWorkflowCancelled,\n    82→\t\tCreatedAt:     now,\n    83→\t})\n    84→}\n    85→\n    86→// AdvanceRun inspects the current state of a workflow run and takes the\n    87→// appropriate next action: schedule an activity, advance to the next step,\n    88→// complete the run, or fail the run.\n    89→func (e *Executor) AdvanceRun(runID string) error {\n    90→\trun, err := e.store.GetRun(runID)\n    91→\tif err != nil {\n    92→\t\treturn fmt.Errorf(\"advance run: get run: %w\", err)\n    93→\t}\n    94→\n    95→\tif run.Status != model.StatusRunning {\n    96→\t\treturn nil // nothing to do for non-running workflows\n    97→\t}\n    98→\n    99→\twf, err := e.store.GetWorkflow(run.WorkflowID)\n   100→\tif err != nil {\n   101→\t\treturn fmt.Errorf(\"advance run: get workflow: %w\", err)\n   102→\t}\n   103→\n   104→\tactivities := wf.Definition.Activities\n   105→\tif len(activities) == 0 {\n   106→\t\t// No activities defined — mark run completed immediately.\n   107→\t\treturn e.completeRun(run, \"\")\n   108→\t}\n   109→\n   110→\tactivityRuns, err := e.store.GetActivityRunsByRunID(runID)\n   111→\tif err != nil {\n   112→\t\treturn fmt.Errorf(\"advance run: get activity runs: %w\", err)\n   113→\t}\n   114→\n   115→\tstepIndex := run.CurrentStep\n   116→\n   117→\t// Guard: if current step is past the last activity, the run is done.\n   118→\tif stepIndex >= len(activities) {\n   119→\t\tlastOutput := \"\"\n   120→\t\tif ar := findActivityRunByStep(activityRuns, stepIndex-1); ar != nil {\n   121→\t\t\tlastOutput = ar.Output\n   122→\t\t}\n   123→\t\treturn e.completeRun(run, lastOutput)\n   124→\t}\n   125→\n   126→\tcurrentSpec := activities[stepIndex]\n   127→\tcurrentAR := findActivityRunByStep(activityRuns, stepIndex)\n   128→\n   129→\tif currentAR == nil {\n   130→\t\t// No activity run for this step yet — schedule one.\n   131→\t\tinput := resolveInputExpr(currentSpec.InputExpr, run, activityRuns)\n   132→\t\treturn e.scheduleActivity(run, currentSpec, stepIndex, input)\n   133→\t}\n   134→\n   135→\tswitch currentAR.Status {\n   136→\tcase model.StatusCompleted:\n   137→\t\t// Move to the next step.\n   138→\t\tnextStep := stepIndex + 1\n   139→\t\trun.CurrentStep = nextStep\n   140→\n   141→\t\tif nextStep >= len(activities) {\n   142→\t\t\t// That was the last activity — complete the run.\n   143→\t\t\trun.Output = currentAR.Output\n   144→\t\t\treturn e.completeRun(run, currentAR.Output)\n   145→\t\t}\n   146→\n   147→\t\tif err := e.store.UpdateRun(run); err != nil {\n   148→\t\t\treturn fmt.Errorf(\"advance run: update run step: %w\", err)\n   149→\t\t}\n   150→\n   151→\t\t// Refresh activity runs since we may need them for input resolution.\n   152→\t\tactivityRuns, err = e.store.GetActivityRunsByRunID(runID)\n   153→\t\tif err != nil {\n   154→\t\t\treturn fmt.Errorf(\"advance run: refresh activity runs: %w\", err)\n   155→\t\t}\n   156→\n   157→\t\tnextSpec := activities[nextStep]\n   158→\t\tinput := resolveInputExpr(nextSpec.InputExpr, run, activityRuns)\n   159→\t\treturn e.scheduleActivity(run, nextSpec, nextStep, input)\n   160→\n   161→\tcase model.StatusFailed:\n   162→\t\tif currentAR.Attempts >= currentAR.MaxRetries+1 {\n   163→\t\t\t// Retries exhausted — fail the workflow run.\n   164→\t\t\treturn e.failRun(run, fmt.Sprintf(\"activity %q failed after %d attempts\", currentAR.ActivityName, currentAR.Attempts))\n   165→\t\t}\n   166→\t\t// Otherwise, still has retries — do nothing (worker will retry).\n   167→\t\treturn nil\n   168→\n   169→\tcase model.StatusPending, model.StatusRunning:\n   170→\t\t// Activity is in progress — nothing to do.\n   171→\t\treturn nil\n   172→\n   173→\tdefault:\n   174→\t\treturn nil\n   175→\t}\n   176→}\n   177→\n   178→// scheduleActivity creates a new ActivityRun and emits an activity_scheduled event.\n   179→func (e *Executor) scheduleActivity(run *model.WorkflowRun, spec model.ActivitySpec, stepIndex int, input string) error {\n   180→\tnow := time.Now().UTC()\n   181→\tar := &model.ActivityRun{\n   182→\t\tID:             uuid.New().String(),\n   183→\t\tWorkflowRunID:  run.ID,\n   184→\t\tActivityName:   spec.Name,\n   185→\t\tStepIndex:      stepIndex,\n   186→\t\tStatus:         model.StatusPending,\n   187→\t\tInput:          input,\n   188→\t\tAttempts:       0,\n   189→\t\tMaxRetries:     spec.MaxRetries,\n   190→\t\tTimeoutSeconds: spec.TimeoutSeconds,\n   191→\t\tCreatedAt:      now,\n   192→\t}\n   193→\n   194→\tif err := e.store.CreateActivityRun(ar); err != nil {\n   195→\t\treturn fmt.Errorf(\"schedule activity: create activity run: %w\", err)\n   196→\t}\n   197→\n   198→\treturn e.store.AppendEvent(&model.Event{\n   199→\t\tWorkflowRunID: run.ID,\n   200→\t\tActivityRunID: ar.ID,\n   201→\t\tEventType:     model.EventActivityScheduled,\n   202→\t\tPayload:       input,\n   203→\t\tCreatedAt:     now,\n   204→\t})\n   205→}\n   206→\n   207→// completeRun marks a workflow run as completed and emits a workflow_completed event.\n   208→func (e *Executor) completeRun(run *model.WorkflowRun, output string) error {\n   209→\tnow := time.Now().UTC()\n   210→\trun.Status = model.StatusCompleted\n   211→\trun.Output = output\n   212→\trun.CompletedAt = &now\n   213→\n   214→\tif err := e.store.UpdateRun(run); err != nil {\n   215→\t\treturn fmt.Errorf(\"complete run: update run: %w\", err)\n   216→\t}\n   217→\n   218→\treturn e.store.AppendEvent(&model.Event{\n   219→\t\tWorkflowRunID: run.ID,\n   220→\t\tEventType:     model.EventWorkflowCompleted,\n   221→\t\tPayload:       output,\n   222→\t\tCreatedAt:     now,\n   223→\t})\n   224→}\n   225→\n   226→// failRun marks a workflow run as failed and emits a workflow_failed event.\n   227→func (e *Executor) failRun(run *model.WorkflowRun, reason string) error {\n   228→\tnow := time.Now().UTC()\n   229→\trun.Status = model.StatusFailed\n   230→\trun.CompletedAt = &now\n   231→\n   232→\tif err := e.store.UpdateRun(run); err != nil {\n   233→\t\treturn fmt.Errorf(\"fail run: update run: %w\", err)\n   234→\t}\n   235→\n   236→\treturn e.store.AppendEvent(&model.Event{\n   237→\t\tWorkflowRunID: run.ID,\n   238→\t\tEventType:     model.EventWorkflowFailed,\n   239→\t\tPayload:       reason,\n   240→\t\tCreatedAt:     now,\n   241→\t})\n   242→}\n   243→\n   244→// findActivityRunByStep returns the activity run at the given step index, or nil.\n   245→func findActivityRunByStep(runs []model.ActivityRun, stepIndex int) *model.ActivityRun {\n   246→\tfor i := range runs {\n   247→\t\tif runs[i].StepIndex == stepIndex {\n   248→\t\t\treturn &runs[i]\n   249→\t\t}\n   250→\t}\n   251→\treturn nil\n   252→}\n   253→\n   254→// stepsOutputRegex matches expressions like $.steps[0].output\n   255→var stepsOutputRegex = regexp.MustCompile(`^\\$\\.steps\\[(\\d+)\\]\\.output$`)\n   256→\n   257→// resolveInputExpr evaluates a simple expression against the run context.\n   258→//\n   259→//\t\"$.input\"              -> the workflow run's input\n   260→//\t\"$.steps[N].output\"    -> the Nth activity run's output (by step_index)\n   261→//\t\"\"  / anything else    -> the workflow run's input (default)\n   262→func resolveInputExpr(expr string, run *model.WorkflowRun, activityRuns []model.ActivityRun) string {\n   263→\tswitch {\n   264→\tcase expr == \"$.input\":\n   265→\t\treturn run.Input\n   266→\n   267→\tcase stepsOutputRegex.MatchString(expr):\n   268→\t\tmatches := stepsOutputRegex.FindStringSubmatch(expr)\n   269→\t\tidx, _ := strconv.Atoi(matches[1])\n   270→\t\tif ar := findActivityRunByStep(activityRuns, idx); ar != nil {\n   271→\t\t\treturn ar.Output\n   272→\t\t}\n   273→\t\treturn \"\"\n   274→\n   275→\tdefault:\n   276→\t\treturn run.Input\n   277→\t}\n   278→}\n   279→"}]},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"719804a4-865c-4a65-af38-cd6d795feb64"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01MA7Ck7KLPh2rfQQD54qbZs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TP1wJErFUDY8KXsdxA9jYA","name":"Read","input":{"file_path":"/Users/michaelhabib/dev/teams-sbx/agent-orchestra/examples/miniflow/internal/executor/scheduler.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7340,"cache_read_input_tokens":22558,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7340},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"256153c8-2a28-4a7b-a825-70b00748947c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TP1wJErFUDY8KXsdxA9jYA","type":"tool_result","content":"     1→package executor\n     2→\n     3→import (\n     4→\t\"log\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→// Scheduler periodically polls the store for pending and running workflow\n     9→// runs and drives them forward via the Executor.\n    10→type Scheduler struct {\n    11→\texecutor *Executor\n    12→\tstore    RunStore\n    13→\tinterval time.Duration\n    14→\tquit     chan struct{}\n    15→}\n    16→\n    17→// NewScheduler creates a Scheduler that ticks at the given interval.\n    18→func NewScheduler(executor *Executor, store RunStore, interval time.Duration) *Scheduler {\n    19→\treturn &Scheduler{\n    20→\t\texecutor: executor,\n    21→\t\tstore:    store,\n    22→\t\tinterval: interval,\n    23→\t\tquit:     make(chan struct{}),\n    24→\t}\n    25→}\n    26→\n    27→// Start begins polling in a background goroutine.\n    28→func (s *Scheduler) Start() {\n    29→\tgo s.loop()\n    30→}\n    31→\n    32→// Stop signals the polling goroutine to exit and returns immediately.\n    33→func (s *Scheduler) Stop() {\n    34→\tclose(s.quit)\n    35→}\n    36→\n    37→func (s *Scheduler) loop() {\n    38→\tticker := time.NewTicker(s.interval)\n    39→\tdefer ticker.Stop()\n    40→\n    41→\tfor {\n    42→\t\tselect {\n    43→\t\tcase <-s.quit:\n    44→\t\t\treturn\n    45→\t\tcase <-ticker.C:\n    46→\t\t\ts.tick()\n    47→\t\t}\n    48→\t}\n    49→}\n    50→\n    51→func (s *Scheduler) tick() {\n    52→\t// Start any pending runs.\n    53→\tpending, err := s.store.ListRuns(\"pending\", 100)\n    54→\tif err != nil {\n    55→\t\tlog.Printf(\"scheduler: list pending runs: %v\", err)\n    56→\t} else {\n    57→\t\tfor _, run := range pending {\n    58→\t\t\tif err := s.executor.StartRun(run.ID); err != nil {\n    59→\t\t\t\tlog.Printf(\"scheduler: start run %s: %v\", run.ID, err)\n    60→\t\t\t}\n    61→\t\t}\n    62→\t}\n    63→\n    64→\t// Advance any running runs.\n    65→\trunning, err := s.store.ListRuns(\"running\", 100)\n    66→\tif err != nil {\n    67→\t\tlog.Printf(\"scheduler: list running runs: %v\", err)\n    68→\t} else {\n    69→\t\tfor _, run := range running {\n    70→\t\t\tif err := s.executor.AdvanceRun(run.ID); err != nil {\n    71→\t\t\t\tlog.Printf(\"scheduler: advance run %s: %v\", run.ID, err)\n    72→\t\t\t}\n    73→\t\t}\n    74→\t}\n    75→}\n    76→"}]},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"7c024750-fe1b-43ed-9c7e-98055c741c21"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01BNYNy2Ld3BziQkh4G6zEad","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KEYdKqHiuexMVMe8taAY8K","name":"Read","input":{"file_path":"/Users/michaelhabib/dev/teams-sbx/agent-orchestra/examples/miniflow/cmd/server/main.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":9167,"cache_read_input_tokens":29898,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9167},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"d304375b-37a2-465c-99d1-2699fea148c2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KEYdKqHiuexMVMe8taAY8K","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"log\"\n     6→\t\"net/http\"\n     7→\t\"os\"\n     8→\t\"os/signal\"\n     9→\t\"syscall\"\n    10→\t\"time\"\n    11→\n    12→\t\"miniflow/internal/activity\"\n    13→\t\"miniflow/internal/config\"\n    14→\t\"miniflow/internal/executor\"\n    15→\t\"miniflow/internal/handler\"\n    16→\t\"miniflow/internal/store\"\n    17→)\n    18→\n    19→func main() {\n    20→\tcfg := config.Load()\n    21→\n    22→\ts, err := store.NewStore(cfg.DBPath)\n    23→\tif err != nil {\n    24→\t\tlog.Fatalf(\"failed to open store: %v\", err)\n    25→\t}\n    26→\tdefer s.Close()\n    27→\n    28→\t// Activity registry with built-in handlers.\n    29→\tregistry := activity.NewRegistry()\n    30→\tactivity.RegisterBuiltins(registry)\n    31→\n    32→\t// Activity worker pool.\n    33→\tworkers := activity.NewWorkerPool(s, registry, cfg.WorkerCount, 500*time.Millisecond)\n    34→\tworkers.Start()\n    35→\n    36→\t// Workflow executor and scheduler.\n    37→\tex := executor.NewExecutor(s)\n    38→\tsched := executor.NewScheduler(ex, s, 500*time.Millisecond)\n    39→\tsched.Start()\n    40→\n    41→\t// HTTP server.\n    42→\trouter := handler.New(s, ex)\n    43→\tsrv := &http.Server{\n    44→\t\tAddr:    \":\" + cfg.Port,\n    45→\t\tHandler: router,\n    46→\t}\n    47→\n    48→\t// Graceful shutdown.\n    49→\tquit := make(chan os.Signal, 1)\n    50→\tsignal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)\n    51→\n    52→\tgo func() {\n    53→\t\tlog.Printf(\"miniflow server listening on :%s\", cfg.Port)\n    54→\t\tif err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n    55→\t\t\tlog.Fatalf(\"server error: %v\", err)\n    56→\t\t}\n    57→\t}()\n    58→\n    59→\t<-quit\n    60→\tlog.Println(\"shutting down...\")\n    61→\n    62→\tsched.Stop()\n    63→\tworkers.Stop()\n    64→\n    65→\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    66→\tdefer cancel()\n    67→\tif err := srv.Shutdown(ctx); err != nil {\n    68→\t\tlog.Fatalf(\"server shutdown error: %v\", err)\n    69→\t}\n    70→\tlog.Println(\"miniflow stopped\")\n    71→}\n    72→"}]},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"ee35df45-fd6a-4efa-b796-9cae7f69b41f"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01BNYNy2Ld3BziQkh4G6zEad","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YG51uHk1vFzmmq9Lu5ZRzY","name":"Read","input":{"file_path":"/Users/michaelhabib/dev/teams-sbx/agent-orchestra/examples/miniflow/cmd/cli/main.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":9167,"cache_read_input_tokens":29898,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9167},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"8fd78e19-4272-4d6d-92d9-40aa94f85196"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YG51uHk1vFzmmq9Lu5ZRzY","type":"tool_result","content":"     1→// Command miniflow is the CLI client for the miniflow workflow engine.\n     2→package main\n     3→\n     4→import (\n     5→\t\"encoding/json\"\n     6→\t\"flag\"\n     7→\t\"fmt\"\n     8→\t\"math\"\n     9→\t\"os\"\n    10→\t\"sort\"\n    11→\t\"strings\"\n    12→\t\"time\"\n    13→\n    14→\t\"miniflow/internal/client\"\n    15→)\n    16→\n    17→// ── Color helpers ──────────────────────────────────────────────────────────\n    18→\n    19→var noColor = os.Getenv(\"NO_COLOR\") != \"\"\n    20→\n    21→const (\n    22→\tcolorReset  = \"\\033[0m\"\n    23→\tcolorRed    = \"\\033[31m\"\n    24→\tcolorGreen  = \"\\033[32m\"\n    25→\tcolorYellow = \"\\033[33m\"\n    26→\tcolorBlue   = \"\\033[34m\"\n    27→\tcolorGray   = \"\\033[90m\"\n    28→\tcolorBold   = \"\\033[1m\"\n    29→\tcolorCyan   = \"\\033[36m\"\n    30→)\n    31→\n    32→func c(color, text string) string {\n    33→\tif noColor {\n    34→\t\treturn text\n    35→\t}\n    36→\treturn color + text + colorReset\n    37→}\n    38→\n    39→func bold(text string) string { return c(colorBold, text) }\n    40→\n    41→func statusColor(status string) string {\n    42→\tswitch status {\n    43→\tcase \"completed\":\n    44→\t\treturn colorGreen\n    45→\tcase \"running\":\n    46→\t\treturn colorYellow\n    47→\tcase \"failed\":\n    48→\t\treturn colorRed\n    49→\tcase \"pending\":\n    50→\t\treturn colorBlue\n    51→\tcase \"cancelled\":\n    52→\t\treturn colorGray\n    53→\tdefault:\n    54→\t\treturn colorReset\n    55→\t}\n    56→}\n    57→\n    58→func coloredStatus(status string) string {\n    59→\treturn c(statusColor(status), status)\n    60→}\n    61→\n    62→// ── Formatting helpers ─────────────────────────────────────────────────────\n    63→\n    64→func shortID(id string) string {\n    65→\tif len(id) > 8 {\n    66→\t\treturn id[:8]\n    67→\t}\n    68→\treturn id\n    69→}\n    70→\n    71→func humanAge(t time.Time) string {\n    72→\td := time.Since(t)\n    73→\tswitch {\n    74→\tcase d < time.Minute:\n    75→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n    76→\tcase d < time.Hour:\n    77→\t\treturn fmt.Sprintf(\"%dm\", int(d.Minutes()))\n    78→\tcase d < 24*time.Hour:\n    79→\t\treturn fmt.Sprintf(\"%dh\", int(d.Hours()))\n    80→\tdefault:\n    81→\t\treturn fmt.Sprintf(\"%dd\", int(d.Hours()/24))\n    82→\t}\n    83→}\n    84→\n    85→func humanDuration(start, end *time.Time) string {\n    86→\tif start == nil {\n    87→\t\treturn \"-\"\n    88→\t}\n    89→\tvar d time.Duration\n    90→\tif end != nil {\n    91→\t\td = end.Sub(*start)\n    92→\t} else {\n    93→\t\td = time.Since(*start)\n    94→\t}\n    95→\tif d < time.Second {\n    96→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n    97→\t}\n    98→\tif d < time.Minute {\n    99→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n   100→\t}\n   101→\treturn fmt.Sprintf(\"%.1fm\", d.Minutes())\n   102→}\n   103→\n   104→// printTable renders a simple aligned table to stdout.\n   105→func printTable(headers []string, rows [][]string) {\n   106→\twidths := make([]int, len(headers))\n   107→\tfor i, h := range headers {\n   108→\t\twidths[i] = len(h)\n   109→\t}\n   110→\tfor _, row := range rows {\n   111→\t\tfor i, cell := range row {\n   112→\t\t\tif i < len(widths) && len(cell) > widths[i] {\n   113→\t\t\t\twidths[i] = len(cell)\n   114→\t\t\t}\n   115→\t\t}\n   116→\t}\n   117→\n   118→\t// Header\n   119→\tfor i, h := range headers {\n   120→\t\tfmt.Printf(\"%-*s\", widths[i]+2, bold(h))\n   121→\t}\n   122→\tfmt.Println()\n   123→\t// Separator\n   124→\tfor i := range headers {\n   125→\t\tfmt.Print(strings.Repeat(\"-\", widths[i]+2))\n   126→\t}\n   127→\tfmt.Println()\n   128→\t// Rows\n   129→\tfor _, row := range rows {\n   130→\t\tfor i, cell := range row {\n   131→\t\t\tif i < len(widths) {\n   132→\t\t\t\tfmt.Printf(\"%-*s\", widths[i]+2, cell)\n   133→\t\t\t}\n   134→\t\t}\n   135→\t\tfmt.Println()\n   136→\t}\n   137→}\n   138→\n   139→// ── Main entrypoint ────────────────────────────────────────────────────────\n   140→\n   141→func main() {\n   142→\tif len(os.Args) < 2 {\n   143→\t\tprintUsage()\n   144→\t\tos.Exit(1)\n   145→\t}\n   146→\n   147→\tbaseURL := os.Getenv(\"MINIFLOW_API\")\n   148→\tif baseURL == \"\" {\n   149→\t\tbaseURL = \"http://localhost:8080\"\n   150→\t}\n   151→\tcli := client.NewClient(baseURL)\n   152→\n   153→\tsubcmd := os.Args[1]\n   154→\targs := os.Args[2:]\n   155→\n   156→\tvar err error\n   157→\tswitch subcmd {\n   158→\tcase \"register\":\n   159→\t\terr = cmdRegister(cli, args)\n   160→\tcase \"run\":\n   161→\t\terr = cmdRun(cli, args)\n   162→\tcase \"status\":\n   163→\t\terr = cmdStatus(cli, args)\n   164→\tcase \"events\":\n   165→\t\terr = cmdEvents(cli, args)\n   166→\tcase \"list\":\n   167→\t\terr = cmdList(cli, args)\n   168→\tcase \"cancel\":\n   169→\t\terr = cmdCancel(cli, args)\n   170→\tcase \"workflows\":\n   171→\t\terr = cmdWorkflows(cli, args)\n   172→\tcase \"stats\":\n   173→\t\terr = cmdStats(cli, args)\n   174→\tcase \"help\", \"--help\", \"-h\":\n   175→\t\tprintUsage()\n   176→\t\treturn\n   177→\tdefault:\n   178→\t\tfmt.Fprintf(os.Stderr, \"Unknown command: %s\\n\\n\", subcmd)\n   179→\t\tprintUsage()\n   180→\t\tos.Exit(1)\n   181→\t}\n   182→\tif err != nil {\n   183→\t\tfmt.Fprintf(os.Stderr, \"Error: %v\\n\", err)\n   184→\t\tos.Exit(1)\n   185→\t}\n   186→}\n   187→\n   188→// ── Commands ───────────────────────────────────────────────────────────────\n   189→\n   190→func cmdRegister(cli *client.Client, args []string) error {\n   191→\tif len(args) < 1 {\n   192→\t\treturn fmt.Errorf(\"usage: miniflow register <workflow.json>\")\n   193→\t}\n   194→\tdata, err := os.ReadFile(args[0])\n   195→\tif err != nil {\n   196→\t\treturn fmt.Errorf(\"reading file: %w\", err)\n   197→\t}\n   198→\n   199→\tvar req struct {\n   200→\t\tName       string                    `json:\"name\"`\n   201→\t\tDefinition client.WorkflowDefinition `json:\"definition\"`\n   202→\t}\n   203→\tif err := json.Unmarshal(data, &req); err != nil {\n   204→\t\treturn fmt.Errorf(\"parsing JSON: %w\", err)\n   205→\t}\n   206→\tif req.Name == \"\" {\n   207→\t\treturn fmt.Errorf(\"workflow JSON must contain a \\\"name\\\" field\")\n   208→\t}\n   209→\n   210→\twf, err := cli.RegisterWorkflow(req.Name, req.Definition)\n   211→\tif err != nil {\n   212→\t\treturn err\n   213→\t}\n   214→\tfmt.Printf(\"%s Workflow %s registered (ID: %s)\\n\",\n   215→\t\tc(colorGreen, \"OK\"),\n   216→\t\tbold(wf.Name),\n   217→\t\tc(colorGray, shortID(wf.ID)),\n   218→\t)\n   219→\treturn nil\n   220→}\n   221→\n   222→func cmdRun(cli *client.Client, args []string) error {\n   223→\tfs := flag.NewFlagSet(\"run\", flag.ContinueOnError)\n   224→\tinput := fs.String(\"input\", \"{}\", \"JSON input for the workflow run\")\n   225→\tif err := fs.Parse(args); err != nil {\n   226→\t\treturn err\n   227→\t}\n   228→\tif fs.NArg() < 1 {\n   229→\t\treturn fmt.Errorf(\"usage: miniflow run <workflow-name> [--input '{}']\")\n   230→\t}\n   231→\tworkflowName := fs.Arg(0)\n   232→\n   233→\trun, err := cli.StartRun(workflowName, *input)\n   234→\tif err != nil {\n   235→\t\treturn err\n   236→\t}\n   237→\tfmt.Printf(\"%s Run started: %s\\n\",\n   238→\t\tc(colorGreen, \"OK\"),\n   239→\t\tbold(run.ID),\n   240→\t)\n   241→\treturn nil\n   242→}\n   243→\n   244→func cmdStatus(cli *client.Client, args []string) error {\n   245→\tif len(args) < 1 {\n   246→\t\treturn fmt.Errorf(\"usage: miniflow status <run-id>\")\n   247→\t}\n   248→\trunID := args[0]\n   249→\n   250→\tdetail, err := cli.GetRun(runID)\n   251→\tif err != nil {\n   252→\t\treturn err\n   253→\t}\n   254→\n   255→\t// Run info header\n   256→\tfmt.Println(bold(\"Run Information\"))\n   257→\tfmt.Println(strings.Repeat(\"-\", 50))\n   258→\tfmt.Printf(\"  %-14s %s\\n\", \"Run ID:\", detail.ID)\n   259→\tfmt.Printf(\"  %-14s %s\\n\", \"Workflow ID:\", detail.WorkflowID)\n   260→\tfmt.Printf(\"  %-14s %s\\n\", \"Status:\", coloredStatus(detail.Status))\n   261→\tfmt.Printf(\"  %-14s %d\\n\", \"Current Step:\", detail.CurrentStep)\n   262→\tfmt.Printf(\"  %-14s %s\\n\", \"Created:\", detail.CreatedAt.Local().Format(time.RFC3339))\n   263→\tif detail.StartedAt != nil {\n   264→\t\tfmt.Printf(\"  %-14s %s\\n\", \"Started:\", detail.StartedAt.Local().Format(time.RFC3339))\n   265→\t}\n   266→\tif detail.CompletedAt != nil {\n   267→\t\tfmt.Printf(\"  %-14s %s\\n\", \"Completed:\", detail.CompletedAt.Local().Format(time.RFC3339))\n   268→\t\tfmt.Printf(\"  %-14s %s\\n\", \"Duration:\", humanDuration(detail.StartedAt, detail.CompletedAt))\n   269→\t}\n   270→\tif detail.Input != \"\" && detail.Input != \"{}\" {\n   271→\t\tfmt.Printf(\"  %-14s %s\\n\", \"Input:\", detail.Input)\n   272→\t}\n   273→\tif detail.Output != \"\" {\n   274→\t\tfmt.Printf(\"  %-14s %s\\n\", \"Output:\", detail.Output)\n   275→\t}\n   276→\n   277→\t// Activity table\n   278→\tif len(detail.Activities) > 0 {\n   279→\t\tfmt.Println()\n   280→\t\tfmt.Println(bold(\"Activities\"))\n   281→\n   282→\t\theaders := []string{\"NAME\", \"STATUS\", \"ATTEMPTS\", \"DURATION\"}\n   283→\t\tvar rows [][]string\n   284→\t\tfor _, a := range detail.Activities {\n   285→\t\t\trows = append(rows, []string{\n   286→\t\t\t\ta.ActivityName,\n   287→\t\t\t\tcoloredStatus(a.Status),\n   288→\t\t\t\tfmt.Sprintf(\"%d/%d\", a.Attempts, a.MaxRetries+1),\n   289→\t\t\t\thumanDuration(a.StartedAt, a.CompletedAt),\n   290→\t\t\t})\n   291→\t\t}\n   292→\t\tprintTable(headers, rows)\n   293→\t}\n   294→\treturn nil\n   295→}\n   296→\n   297→func cmdEvents(cli *client.Client, args []string) error {\n   298→\tif len(args) < 1 {\n   299→\t\treturn fmt.Errorf(\"usage: miniflow events <run-id>\")\n   300→\t}\n   301→\trunID := args[0]\n   302→\n   303→\tevents, err := cli.GetEvents(runID)\n   304→\tif err != nil {\n   305→\t\treturn err\n   306→\t}\n   307→\tif len(events) == 0 {\n   308→\t\tfmt.Println(c(colorGray, \"No events found.\"))\n   309→\t\treturn nil\n   310→\t}\n   311→\n   312→\tfmt.Println(bold(\"Event Timeline\"))\n   313→\tfmt.Println()\n   314→\n   315→\tfor i, ev := range events {\n   316→\t\ttimestamp := ev.CreatedAt.Local().Format(\"15:04:05.000\")\n   317→\t\teventColor := eventTypeColor(ev.EventType)\n   318→\t\tconnector := \"|\"\n   319→\t\tif i == len(events)-1 {\n   320→\t\t\tconnector = \" \"\n   321→\t\t}\n   322→\t\tfmt.Printf(\"  %s  %s  %s\\n\",\n   323→\t\t\tc(colorGray, timestamp),\n   324→\t\t\tc(eventColor, fmt.Sprintf(\"%-28s\", ev.EventType)),\n   325→\t\t\tactivityLabel(ev.ActivityRunID),\n   326→\t\t)\n   327→\t\tif ev.Payload != \"\" && ev.Payload != \"{}\" {\n   328→\t\t\tfmt.Printf(\"  %s  %s  %s\\n\",\n   329→\t\t\t\tstrings.Repeat(\" \", 12),\n   330→\t\t\t\tc(colorGray, connector),\n   331→\t\t\t\tc(colorGray, truncate(ev.Payload, 80)),\n   332→\t\t\t)\n   333→\t\t} else {\n   334→\t\t\tfmt.Printf(\"  %s  %s\\n\",\n   335→\t\t\t\tstrings.Repeat(\" \", 12),\n   336→\t\t\t\tc(colorGray, connector),\n   337→\t\t\t)\n   338→\t\t}\n   339→\t}\n   340→\treturn nil\n   341→}\n   342→\n   343→func cmdList(cli *client.Client, args []string) error {\n   344→\tfs := flag.NewFlagSet(\"list\", flag.ContinueOnError)\n   345→\tstatus := fs.String(\"status\", \"\", \"Filter by status\")\n   346→\tlimit := fs.Int(\"limit\", 20, \"Maximum number of runs to list\")\n   347→\tif err := fs.Parse(args); err != nil {\n   348→\t\treturn err\n   349→\t}\n   350→\n   351→\truns, err := cli.ListRuns(*status, *limit)\n   352→\tif err != nil {\n   353→\t\treturn err\n   354→\t}\n   355→\tif len(runs) == 0 {\n   356→\t\tfmt.Println(c(colorGray, \"No runs found.\"))\n   357→\t\treturn nil\n   358→\t}\n   359→\n   360→\theaders := []string{\"ID\", \"WORKFLOW\", \"STATUS\", \"STEP\", \"AGE\"}\n   361→\tvar rows [][]string\n   362→\tfor _, r := range runs {\n   363→\t\trows = append(rows, []string{\n   364→\t\t\tshortID(r.ID),\n   365→\t\t\tr.WorkflowID,\n   366→\t\t\tcoloredStatus(r.Status),\n   367→\t\t\tfmt.Sprintf(\"%d\", r.CurrentStep),\n   368→\t\t\thumanAge(r.CreatedAt),\n   369→\t\t})\n   370→\t}\n   371→\tprintTable(headers, rows)\n   372→\treturn nil\n   373→}\n   374→\n   375→func cmdCancel(cli *client.Client, args []string) error {\n   376→\tif len(args) < 1 {\n   377→\t\treturn fmt.Errorf(\"usage: miniflow cancel <run-id>\")\n   378→\t}\n   379→\trunID := args[0]\n   380→\tif err := cli.CancelRun(runID); err != nil {\n   381→\t\treturn err\n   382→\t}\n   383→\tfmt.Printf(\"%s Run %s cancelled.\\n\",\n   384→\t\tc(colorGreen, \"OK\"),\n   385→\t\tbold(shortID(runID)),\n   386→\t)\n   387→\treturn nil\n   388→}\n   389→\n   390→func cmdWorkflows(cli *client.Client, _ []string) error {\n   391→\twfs, err := cli.ListWorkflows()\n   392→\tif err != nil {\n   393→\t\treturn err\n   394→\t}\n   395→\tif len(wfs) == 0 {\n   396→\t\tfmt.Println(c(colorGray, \"No workflows registered.\"))\n   397→\t\treturn nil\n   398→\t}\n   399→\n   400→\theaders := []string{\"NAME\", \"ID\", \"ACTIVITIES\", \"CREATED\"}\n   401→\tvar rows [][]string\n   402→\tfor _, wf := range wfs {\n   403→\t\trows = append(rows, []string{\n   404→\t\t\tbold(wf.Name),\n   405→\t\t\tshortID(wf.ID),\n   406→\t\t\tfmt.Sprintf(\"%d\", len(wf.Definition.Activities)),\n   407→\t\t\thumanAge(wf.CreatedAt),\n   408→\t\t})\n   409→\t}\n   410→\tprintTable(headers, rows)\n   411→\treturn nil\n   412→}\n   413→\n   414→func cmdStats(cli *client.Client, _ []string) error {\n   415→\tstats, err := cli.Stats()\n   416→\tif err != nil {\n   417→\t\treturn err\n   418→\t}\n   419→\tif len(stats.Counts) == 0 {\n   420→\t\tfmt.Println(c(colorGray, \"No stats available.\"))\n   421→\t\treturn nil\n   422→\t}\n   423→\n   424→\tfmt.Println(bold(\"Run Statistics\"))\n   425→\tfmt.Println()\n   426→\n   427→\t// Find max count for bar scaling\n   428→\tmaxCount := 0\n   429→\tfor _, count := range stats.Counts {\n   430→\t\tif count > maxCount {\n   431→\t\t\tmaxCount = count\n   432→\t\t}\n   433→\t}\n   434→\n   435→\t// Sort statuses for consistent output\n   436→\tstatuses := make([]string, 0, len(stats.Counts))\n   437→\tfor s := range stats.Counts {\n   438→\t\tstatuses = append(statuses, s)\n   439→\t}\n   440→\tsort.Strings(statuses)\n   441→\n   442→\tbarWidth := 40\n   443→\tfor _, status := range statuses {\n   444→\t\tcount := stats.Counts[status]\n   445→\t\tbarLen := 0\n   446→\t\tif maxCount > 0 {\n   447→\t\t\tbarLen = int(math.Round(float64(count) / float64(maxCount) * float64(barWidth)))\n   448→\t\t}\n   449→\t\tif barLen < 1 && count > 0 {\n   450→\t\t\tbarLen = 1\n   451→\t\t}\n   452→\t\tbar := strings.Repeat(\"█\", barLen) + strings.Repeat(\"░\", barWidth-barLen)\n   453→\t\tfmt.Printf(\"  %-12s %s %s\\n\",\n   454→\t\t\tc(statusColor(status), fmt.Sprintf(\"%-10s\", status)),\n   455→\t\t\tc(statusColor(status), bar),\n   456→\t\t\tfmt.Sprintf(\"%d\", count),\n   457→\t\t)\n   458→\t}\n   459→\tfmt.Println()\n   460→\n   461→\t// Total\n   462→\ttotal := 0\n   463→\tfor _, count := range stats.Counts {\n   464→\t\ttotal += count\n   465→\t}\n   466→\tfmt.Printf(\"  %s %d\\n\", bold(\"Total:\"), total)\n   467→\treturn nil\n   468→}\n   469→\n   470→// ── Usage ──────────────────────────────────────────────────────────────────\n   471→\n   472→func printUsage() {\n   473→\tfmt.Println(bold(\"miniflow\") + \" - workflow engine CLI\")\n   474→\tfmt.Println()\n   475→\tfmt.Println(bold(\"USAGE:\"))\n   476→\tfmt.Println(\"  miniflow <command> [arguments]\")\n   477→\tfmt.Println()\n   478→\tfmt.Println(bold(\"COMMANDS:\"))\n   479→\tfmt.Println(\"  register <workflow.json>          Register a workflow from a JSON file\")\n   480→\tfmt.Println(\"  run <workflow-name> [--input '{}'] Start a workflow run\")\n   481→\tfmt.Println(\"  status <run-id>                   Show run details and activity status\")\n   482→\tfmt.Println(\"  events <run-id>                   Show event timeline for a run\")\n   483→\tfmt.Println(\"  list [--status X] [--limit N]     List workflow runs\")\n   484→\tfmt.Println(\"  cancel <run-id>                   Cancel a running workflow\")\n   485→\tfmt.Println(\"  workflows                         List registered workflows\")\n   486→\tfmt.Println(\"  stats                             Show run statistics\")\n   487→\tfmt.Println(\"  help                              Show this help message\")\n   488→\tfmt.Println()\n   489→\tfmt.Println(bold(\"ENVIRONMENT:\"))\n   490→\tfmt.Println(\"  MINIFLOW_API    Base URL of the miniflow server (default: http://localhost:8080)\")\n   491→\tfmt.Println(\"  NO_COLOR        Disable colored output when set\")\n   492→}\n   493→\n   494→// ── Helpers ────────────────────────────────────────────────────────────────\n   495→\n   496→func eventTypeColor(eventType string) string {\n   497→\tswitch {\n   498→\tcase strings.HasSuffix(eventType, \"_completed\"):\n   499→\t\treturn colorGreen\n   500→\tcase strings.HasSuffix(eventType, \"_started\"):\n   501→\t\treturn colorYellow\n   502→\tcase strings.HasSuffix(eventType, \"_failed\"), strings.HasSuffix(eventType, \"_timed_out\"):\n   503→\t\treturn colorRed\n   504→\tcase strings.HasSuffix(eventType, \"_scheduled\"):\n   505→\t\treturn colorBlue\n   506→\tcase strings.HasSuffix(eventType, \"_cancelled\"):\n   507→\t\treturn colorGray\n   508→\tcase strings.HasSuffix(eventType, \"_retried\"):\n   509→\t\treturn colorCyan\n   510→\tdefault:\n   511→\t\treturn colorReset\n   512→\t}\n   513→}\n   514→\n   515→func activityLabel(activityRunID string) string {\n   516→\tif activityRunID == \"\" {\n   517→\t\treturn \"\"\n   518→\t}\n   519→\treturn c(colorGray, \"(activity: \"+shortID(activityRunID)+\")\")\n   520→}\n   521→\n   522→func truncate(s string, maxLen int) string {\n   523→\tif len(s) <= maxLen {\n   524→\t\treturn s\n   525→\t}\n   526→\treturn s[:maxLen-3] 