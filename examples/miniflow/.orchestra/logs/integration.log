{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FMTgsMYC1KxGfwFnKvReQq","type":"tool_result","content":"     1→// Package client provides an HTTP client library for the miniflow workflow engine API.\n     2→package client\n     3→\n     4→import (\n     5→\t\"bytes\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"net/url\"\n    11→\t\"strconv\"\n    12→\t\"time\"\n    13→)\n    14→\n    15→// ---------- Types (mirroring server model types) ----------\n    16→\n    17→// ActivitySpec describes a single activity within a workflow definition.\n    18→type ActivitySpec struct {\n    19→\tName           string `json:\"name\"`\n    20→\tType           string `json:\"type\"`\n    21→\tInputExpr      string `json:\"input_expr\"`\n    22→\tTimeoutSeconds int    `json:\"timeout_seconds\"`\n    23→\tMaxRetries     int    `json:\"max_retries\"`\n    24→}\n    25→\n    26→// WorkflowDefinition holds the ordered list of activities for a workflow.\n    27→type WorkflowDefinition struct {\n    28→\tActivities []ActivitySpec `json:\"activities\"`\n    29→}\n    30→\n    31→// Workflow represents a registered workflow.\n    32→type Workflow struct {\n    33→\tID         string             `json:\"id\"`\n    34→\tName       string             `json:\"name\"`\n    35→\tDefinition WorkflowDefinition `json:\"definition\"`\n    36→\tCreatedAt  time.Time          `json:\"created_at\"`\n    37→}\n    38→\n    39→// WorkflowRun represents a single execution of a workflow.\n    40→type WorkflowRun struct {\n    41→\tID          string     `json:\"id\"`\n    42→\tWorkflowID  string     `json:\"workflow_id\"`\n    43→\tStatus      string     `json:\"status\"`\n    44→\tInput       string     `json:\"input\"`\n    45→\tOutput      string     `json:\"output\"`\n    46→\tCurrentStep int        `json:\"current_step\"`\n    47→\tStartedAt   *time.Time `json:\"started_at,omitempty\"`\n    48→\tCompletedAt *time.Time `json:\"completed_at,omitempty\"`\n    49→\tCreatedAt   time.Time  `json:\"created_at\"`\n    50→}\n    51→\n    52→// ActivityRun represents the execution of a single activity within a run.\n    53→type ActivityRun struct {\n    54→\tID             string     `json:\"id\"`\n    55→\tWorkflowRunID  string     `json:\"workflow_run_id\"`\n    56→\tActivityName   string     `json:\"activity_name\"`\n    57→\tStepIndex      int        `json:\"step_index\"`\n    58→\tStatus         string     `json:\"status\"`\n    59→\tInput          string     `json:\"input\"`\n    60→\tOutput         string     `json:\"output\"`\n    61→\tAttempts       int        `json:\"attempts\"`\n    62→\tMaxRetries     int        `json:\"max_retries\"`\n    63→\tTimeoutSeconds int        `json:\"timeout_seconds\"`\n    64→\tStartedAt      *time.Time `json:\"started_at,omitempty\"`\n    65→\tCompletedAt    *time.Time `json:\"completed_at,omitempty\"`\n    66→\tLastHeartbeat  *time.Time `json:\"last_heartbeat,omitempty\"`\n    67→\tCreatedAt      time.Time  `json:\"created_at\"`\n    68→}\n    69→\n    70→// Event represents a workflow event in the event history.\n    71→type Event struct {\n    72→\tID            int64     `json:\"id\"`\n    73→\tWorkflowRunID string    `json:\"workflow_run_id\"`\n    74→\tActivityRunID string    `json:\"activity_run_id,omitempty\"`\n    75→\tEventType     string    `json:\"event_type\"`\n    76→\tPayload       string    `json:\"payload\"`\n    77→\tCreatedAt     time.Time `json:\"created_at\"`\n    78→}\n    79→\n    80→// RunDetailResponse is the response returned by GetRun, embedding the run\n    81→// together with its activity runs.\n    82→type RunDetailResponse struct {\n    83→\tWorkflowRun\n    84→\tActivities []ActivityRun `json:\"activities\"`\n    85→}\n    86→\n    87→// StatsResponse contains run counts grouped by status.\n    88→type StatsResponse struct {\n    89→\tCounts map[string]int `json:\"counts\"`\n    90→}\n    91→\n    92→// ---------- Request types ----------\n    93→\n    94→type createWorkflowRequest struct {\n    95→\tName       string             `json:\"name\"`\n    96→\tDefinition WorkflowDefinition `json:\"definition\"`\n    97→}\n    98→\n    99→type startRunRequest struct {\n   100→\tInput string `json:\"input\"`\n   101→}\n   102→\n   103→// ---------- Error type ----------\n   104→\n   105→// APIError is returned when the server responds with a non-2xx status code.\n   106→type APIError struct {\n   107→\tStatusCode int\n   108→\tMessage    string\n   109→}\n   110→\n   111→func (e *APIError) Error() string {\n   112→\treturn fmt.Sprintf(\"miniflow API error (HTTP %d): %s\", e.StatusCode, e.Message)\n   113→}\n   114→\n   115→// ---------- Client ----------\n   116→\n   117→// Client is an HTTP client for the miniflow workflow engine API.\n   118→type Client struct {\n   119→\tbaseURL    string\n   120→\thttpClient *http.Client\n   121→}\n   122→\n   123→// NewClient creates a new Client targeting the given base URL.\n   124→// If baseURL is empty, it defaults to http://localhost:8080.\n   125→func NewClient(baseURL string) *Client {\n   126→\tif baseURL == \"\" {\n   127→\t\tbaseURL = \"http://localhost:8080\"\n   128→\t}\n   129→\treturn &Client{\n   130→\t\tbaseURL: baseURL,\n   131→\t\thttpClient: &http.Client{\n   132→\t\t\tTimeout: 30 * time.Second,\n   133→\t\t},\n   134→\t}\n   135→}\n   136→\n   137→// ---------- Public methods ----------\n   138→\n   139→// RegisterWorkflow registers a new workflow definition with the server.\n   140→func (c *Client) RegisterWorkflow(name string, definition WorkflowDefinition) (*Workflow, error) {\n   141→\tbody := createWorkflowRequest{\n   142→\t\tName:       name,\n   143→\t\tDefinition: definition,\n   144→\t}\n   145→\tvar wf Workflow\n   146→\tif err := c.doJSON(http.MethodPost, \"/api/workflows\", body, &wf); err != nil {\n   147→\t\treturn nil, err\n   148→\t}\n   149→\treturn &wf, nil\n   150→}\n   151→\n   152→// GetWorkflow retrieves a workflow by name.\n   153→func (c *Client) GetWorkflow(name string) (*Workflow, error) {\n   154→\tvar wf Workflow\n   155→\tif err := c.doJSON(http.MethodGet, \"/api/workflows/\"+url.PathEscape(name), nil, &wf); err != nil {\n   156→\t\treturn nil, err\n   157→\t}\n   158→\treturn &wf, nil\n   159→}\n   160→\n   161→// ListWorkflows returns all registered workflows.\n   162→func (c *Client) ListWorkflows() ([]Workflow, error) {\n   163→\tvar wfs []Workflow\n   164→\tif err := c.doJSON(http.MethodGet, \"/api/workflows\", nil, &wfs); err != nil {\n   165→\t\treturn nil, err\n   166→\t}\n   167→\treturn wfs, nil\n   168→}\n   169→\n   170→// StartRun begins a new run of the named workflow with the given input.\n   171→func (c *Client) StartRun(workflowName string, input string) (*WorkflowRun, error) {\n   172→\tbody := startRunRequest{Input: input}\n   173→\tvar run WorkflowRun\n   174→\tif err := c.doJSON(http.MethodPost, \"/api/workflows/\"+url.PathEscape(workflowName)+\"/run\", body, &run); err != nil {\n   175→\t\treturn nil, err\n   176→\t}\n   177→\treturn &run, nil\n   178→}\n   179→\n   180→// GetRun retrieves full details for a run, including its activity runs.\n   181→func (c *Client) GetRun(id string) (*RunDetailResponse, error) {\n   182→\tvar detail RunDetailResponse\n   183→\tif err := c.doJSON(http.MethodGet, \"/api/runs/\"+url.PathEscape(id), nil, &detail); err != nil {\n   184→\t\treturn nil, err\n   185→\t}\n   186→\treturn &detail, nil\n   187→}\n   188→\n   189→// ListRuns lists workflow runs, optionally filtered by status and limited in count.\n   190→// Pass an empty string for status and 0 for limit to skip those filters.\n   191→func (c *Client) ListRuns(status string, limit int) ([]WorkflowRun, error) {\n   192→\tpath := \"/api/runs\"\n   193→\tparams := url.Values{}\n   194→\tif status != \"\" {\n   195→\t\tparams.Set(\"status\", status)\n   196→\t}\n   197→\tif limit > 0 {\n   198→\t\tparams.Set(\"limit\", strconv.Itoa(limit))\n   199→\t}\n   200→\tif len(params) > 0 {\n   201→\t\tpath += \"?\" + params.Encode()\n   202→\t}\n   203→\tvar runs []WorkflowRun\n   204→\tif err := c.doJSON(http.MethodGet, path, nil, &runs); err != nil {\n   205→\t\treturn nil, err\n   206→\t}\n   207→\treturn runs, nil\n   208→}\n   209→\n   210→// GetEvents returns the event history for a run.\n   211→func (c *Client) GetEvents(runID string) ([]Event, error) {\n   212→\tvar events []Event\n   213→\tif err := c.doJSON(http.MethodGet, \"/api/runs/\"+url.PathEscape(runID)+\"/events\", nil, &events); err != nil {\n   214→\t\treturn nil, err\n   215→\t}\n   216→\treturn events, nil\n   217→}\n   218→\n   219→// CancelRun cancels a running workflow run.\n   220→func (c *Client) CancelRun(id string) error {\n   221→\treturn c.doJSON(http.MethodPost, \"/api/runs/\"+url.PathEscape(id)+\"/cancel\", nil, nil)\n   222→}\n   223→\n   224→// Stats returns aggregate run counts grouped by status.\n   225→func (c *Client) Stats() (*StatsResponse, error) {\n   226→\tvar stats StatsResponse\n   227→\tif err := c.doJSON(http.MethodGet, \"/api/stats\", nil, &stats); err != nil {\n   228→\t\treturn nil, err\n   229→\t}\n   230→\treturn &stats, nil\n   231→}\n   232→\n   233→// Health performs a health check against the server. Returns nil if healthy.\n   234→func (c *Client) Health() error {\n   235→\treturn c.doJSON(http.MethodGet, \"/health\", nil, nil)\n   236→}\n   237→\n   238→// ---------- Internal helpers ----------\n   239→\n   240→// doJSON performs an HTTP request, optionally encoding reqBody as JSON, and\n   241→// decoding the response into respBody (if non-nil). Non-2xx responses are\n   242→// returned as *APIError.\n   243→func (c *Client) doJSON(method, path string, reqBody interface{}, respBody interface{}) error {\n   244→\tfullURL := c.baseURL + path\n   245→\n   246→\tvar bodyReader io.Reader\n   247→\tif reqBody != nil {\n   248→\t\tdata, err := json.Marshal(reqBody)\n   249→\t\tif err != nil {\n   250→\t\t\treturn fmt.Errorf(\"marshaling request body: %w\", err)\n   251→\t\t}\n   252→\t\tbodyReader = bytes.NewReader(data)\n   253→\t}\n   254→\n   255→\treq, err := http.NewRequest(method, fullURL, bodyReader)\n   256→\tif err != nil {\n   257→\t\treturn fmt.Errorf(\"creating request: %w\", err)\n   258→\t}\n   259→\tif reqBody != nil {\n   260→\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n   261→\t}\n   262→\n   263→\tresp, err := c.httpClient.Do(req)\n   264→\tif err != nil {\n   265→\t\treturn fmt.Errorf(\"executing request: %w\", err)\n   266→\t}\n   267→\tdefer resp.Body.Close()\n   268→\n   269→\trespData, err := io.ReadAll(resp.Body)\n   270→\tif err != nil {\n   271→\t\treturn fmt.Errorf(\"reading response body: %w\", err)\n   272→\t}\n   273→\n   274→\tif resp.StatusCode < 200 || resp.StatusCode >= 300 {\n   275→\t\tmsg := string(respData)\n   276→\t\t// Try to extract a structured error message.\n   277→\t\tvar errResp struct {\n   278→\t\t\tError string `json:\"error\"`\n   279→\t\t}\n   280→\t\tif json.Unmarshal(respData, &errResp) == nil && errResp.Error != \"\" {\n   281→\t\t\tmsg = errResp.Error\n   282→\t\t}\n   283→\t\treturn &APIError{\n   284→\t\t\tStatusCode: resp.StatusCode,\n   285→\t\t\tMessage:    msg,\n   286→\t\t}\n   287→\t}\n   288→\n   289→\tif respBody != nil && len(respData) > 0 {\n   290→\t\tif err := json.Unmarshal(respData, respBody); err != nil {\n   291→\t\t\treturn fmt.Errorf(\"decoding response: %w\", err)\n   292→\t\t}\n   293→\t}\n   294→\n   295→\treturn nil\n   296→}\n   297→"}]},"parent_tool_use_id":"toolu_01NHF3R5g7kdFioUm6bPGqQp","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"7bd51ac3-d4d0-49d6-bef5-2484d6fa7263"}
