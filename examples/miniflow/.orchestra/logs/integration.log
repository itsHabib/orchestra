{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DizuBW921q7HPm8imVEwiD","type":"tool_result","content":"     1→package store\n     2→\n     3→import (\n     4→\t\"database/sql\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"strings\"\n     8→\t\"sync\"\n     9→\t\"time\"\n    10→\n    11→\t\"miniflow/internal/model\"\n    12→\n    13→\t_ \"modernc.org/sqlite\"\n    14→)\n    15→\n    16→// Store provides persistence for workflows, runs, activity runs, and events.\n    17→type Store struct {\n    18→\tdb      *sql.DB\n    19→\tclaimMu sync.Mutex // serializes ClaimNextActivity to avoid SQLite lock contention\n    20→}\n    21→\n    22→// NewStore opens a SQLite database at the given DSN, creates all required\n    23→// tables and indexes, and returns a ready-to-use Store.\n    24→func NewStore(dsn string) (*Store, error) {\n    25→\tdb, err := sql.Open(\"sqlite\", dsn)\n    26→\tif err != nil {\n    27→\t\treturn nil, fmt.Errorf(\"open db: %w\", err)\n    28→\t}\n    29→\n    30→\t// Enable WAL mode and foreign keys.\n    31→\tfor _, pragma := range []string{\n    32→\t\t\"PRAGMA journal_mode=WAL\",\n    33→\t\t\"PRAGMA foreign_keys=ON\",\n    34→\t} {\n    35→\t\tif _, err := db.Exec(pragma); err != nil {\n    36→\t\t\tdb.Close()\n    37→\t\t\treturn nil, fmt.Errorf(\"exec %s: %w\", pragma, err)\n    38→\t\t}\n    39→\t}\n    40→\n    41→\tif err := createTables(db); err != nil {\n    42→\t\tdb.Close()\n    43→\t\treturn nil, err\n    44→\t}\n    45→\n    46→\treturn &Store{db: db}, nil\n    47→}\n    48→\n    49→func createTables(db *sql.DB) error {\n    50→\tddl := `\n    51→\tCREATE TABLE IF NOT EXISTS workflows (\n    52→\t\tid TEXT PRIMARY KEY,\n    53→\t\tname TEXT UNIQUE NOT NULL,\n    54→\t\tdefinition TEXT NOT NULL,\n    55→\t\tcreated_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    56→\t);\n    57→\n    58→\tCREATE TABLE IF NOT EXISTS workflow_runs (\n    59→\t\tid TEXT PRIMARY KEY,\n    60→\t\tworkflow_id TEXT NOT NULL REFERENCES workflows(id),\n    61→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n    62→\t\tinput TEXT DEFAULT '{}',\n    63→\t\toutput TEXT DEFAULT '',\n    64→\t\tcurrent_step INTEGER DEFAULT 0,\n    65→\t\tstarted_at DATETIME,\n    66→\t\tcompleted_at DATETIME,\n    67→\t\tcreated_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    68→\t);\n    69→\n    70→\tCREATE TABLE IF NOT EXISTS activity_runs (\n    71→\t\tid TEXT PRIMARY KEY,\n    72→\t\tworkflow_run_id TEXT NOT NULL REFERENCES workflow_runs(id),\n    73→\t\tactivity_name TEXT NOT NULL,\n    74→\t\tstep_index INTEGER NOT NULL,\n    75→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n    76→\t\tinput TEXT DEFAULT '{}',\n    77→\t\toutput TEXT DEFAULT '',\n    78→\t\tattempts INTEGER DEFAULT 0,\n    79→\t\tmax_retries INTEGER DEFAULT 3,\n    80→\t\ttimeout_seconds INTEGER DEFAULT 30,\n    81→\t\tstarted_at DATETIME,\n    82→\t\tcompleted_at DATETIME,\n    83→\t\tlast_heartbeat DATETIME,\n    84→\t\tcreated_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    85→\t);\n    86→\n    87→\tCREATE TABLE IF NOT EXISTS events (\n    88→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    89→\t\tworkflow_run_id TEXT NOT NULL REFERENCES workflow_runs(id),\n    90→\t\tactivity_run_id TEXT,\n    91→\t\tevent_type TEXT NOT NULL,\n    92→\t\tpayload TEXT DEFAULT '{}',\n    93→\t\tcreated_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    94→\t);\n    95→\n    96→\tCREATE INDEX IF NOT EXISTS idx_workflow_runs_status ON workflow_runs(status);\n    97→\tCREATE INDEX IF NOT EXISTS idx_workflow_runs_workflow_id ON workflow_runs(workflow_id);\n    98→\tCREATE INDEX IF NOT EXISTS idx_activity_runs_workflow_run_id ON activity_runs(workflow_run_id);\n    99→\tCREATE INDEX IF NOT EXISTS idx_activity_runs_status ON activity_runs(status);\n   100→\tCREATE INDEX IF NOT EXISTS idx_events_workflow_run_id ON events(workflow_run_id);\n   101→\t`\n   102→\tif _, err := db.Exec(ddl); err != nil {\n   103→\t\treturn fmt.Errorf(\"create tables: %w\", err)\n   104→\t}\n   105→\treturn nil\n   106→}\n   107→\n   108→// Close closes the underlying database connection.\n   109→func (s *Store) Close() error {\n   110→\treturn s.db.Close()\n   111→}\n   112→\n   113→// ---------------------------------------------------------------------------\n   114→// Workflows\n   115→// ---------------------------------------------------------------------------\n   116→\n   117→// CreateWorkflow inserts a new workflow. The Definition field is marshalled\n   118→// to JSON for storage. Returns ErrDuplicateWorkflow if the name is taken.\n   119→func (s *Store) CreateWorkflow(w *model.Workflow) error {\n   120→\tdefJSON, err := json.Marshal(w.Definition)\n   121→\tif err != nil {\n   122→\t\treturn fmt.Errorf(\"marshal definition: %w\", err)\n   123→\t}\n   124→\n   125→\t_, err = s.db.Exec(\n   126→\t\t`INSERT INTO workflows (id, name, definition, created_at) VALUES (?, ?, ?, ?)`,\n   127→\t\tw.ID, w.Name, string(defJSON), w.CreatedAt,\n   128→\t)\n   129→\tif err != nil {\n   130→\t\tif strings.Contains(err.Error(), \"UNIQUE constraint failed\") {\n   131→\t\t\treturn ErrDuplicateWorkflow\n   132→\t\t}\n   133→\t\treturn fmt.Errorf(\"insert workflow: %w\", err)\n   134→\t}\n   135→\treturn nil\n   136→}\n   137→\n   138→// GetWorkflow retrieves a workflow by ID. Returns ErrNotFound if absent.\n   139→func (s *Store) GetWorkflow(id string) (*model.Workflow, error) {\n   140→\trow := s.db.QueryRow(\n   141→\t\t`SELECT id, name, definition, created_at FROM workflows WHERE id = ?`, id,\n   142→\t)\n   143→\treturn scanWorkflow(row)\n   144→}\n   145→\n   146→// GetWorkflowByName retrieves a workflow by its unique name. Returns\n   147→// ErrNotFound if absent.\n   148→func (s *Store) GetWorkflowByName(name string) (*model.Workflow, error) {\n   149→\trow := s.db.QueryRow(\n   150→\t\t`SELECT id, name, definition, created_at FROM workflows WHERE name = ?`, name,\n   151→\t)\n   152→\treturn scanWorkflow(row)\n   153→}\n   154→\n   155→// ListWorkflows returns all registered workflows ordered by creation time.\n   156→func (s *Store) ListWorkflows() ([]model.Workflow, error) {\n   157→\trows, err := s.db.Query(\n   158→\t\t`SELECT id, name, definition, created_at FROM workflows ORDER BY created_at ASC`,\n   159→\t)\n   160→\tif err != nil {\n   161→\t\treturn nil, fmt.Errorf(\"list workflows: %w\", err)\n   162→\t}\n   163→\tdefer rows.Close()\n   164→\n   165→\tvar workflows []model.Workflow\n   166→\tfor rows.Next() {\n   167→\t\tw, err := scanWorkflowRow(rows)\n   168→\t\tif err != nil {\n   169→\t\t\treturn nil, err\n   170→\t\t}\n   171→\t\tworkflows = append(workflows, *w)\n   172→\t}\n   173→\treturn workflows, rows.Err()\n   174→}\n   175→\n   176→// scanner is satisfied by both *sql.Row and *sql.Rows.\n   177→type scanner interface {\n   178→\tScan(dest ...any) error\n   179→}\n   180→\n   181→func scanWorkflow(row *sql.Row) (*model.Workflow, error) {\n   182→\tvar w model.Workflow\n   183→\tvar defJSON string\n   184→\tif err := row.Scan(&w.ID, &w.Name, &defJSON, &w.CreatedAt); err != nil {\n   185→\t\tif err == sql.ErrNoRows {\n   186→\t\t\treturn nil, ErrNotFound\n   187→\t\t}\n   188→\t\treturn nil, fmt.Errorf(\"scan workflow: %w\", err)\n   189→\t}\n   190→\tif err := json.Unmarshal([]byte(defJSON), &w.Definition); err != nil {\n   191→\t\treturn nil, fmt.Errorf(\"unmarshal definition: %w\", err)\n   192→\t}\n   193→\treturn &w, nil\n   194→}\n   195→\n   196→func scanWorkflowRow(rows *sql.Rows) (*model.Workflow, error) {\n   197→\tvar w model.Workflow\n   198→\tvar defJSON string\n   199→\tif err := rows.Scan(&w.ID, &w.Name, &defJSON, &w.CreatedAt); err != nil {\n   200→\t\treturn nil, fmt.Errorf(\"scan workflow: %w\", err)\n   201→\t}\n   202→\tif err := json.Unmarshal([]byte(defJSON), &w.Definition); err != nil {\n   203→\t\treturn nil, fmt.Errorf(\"unmarshal definition: %w\", err)\n   204→\t}\n   205→\treturn &w, nil\n   206→}\n   207→\n   208→// ---------------------------------------------------------------------------\n   209→// Workflow Runs\n   210→// ---------------------------------------------------------------------------\n   211→\n   212→// CreateRun inserts a new workflow run.\n   213→func (s *Store) CreateRun(r *model.WorkflowRun) error {\n   214→\t_, err := s.db.Exec(\n   215→\t\t`INSERT INTO workflow_runs (id, workflow_id, status, input, output, current_step, started_at, completed_at, created_at)\n   216→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   217→\t\tr.ID, r.WorkflowID, r.Status, r.Input, r.Output, r.CurrentStep,\n   218→\t\tnullTime(r.StartedAt), nullTime(r.CompletedAt), r.CreatedAt,\n   219→\t)\n   220→\tif err != nil {\n   221→\t\treturn fmt.Errorf(\"insert run: %w\", err)\n   222→\t}\n   223→\treturn nil\n   224→}\n   225→\n   226→// GetRun retrieves a workflow run by ID. Returns ErrNotFound if absent.\n   227→func (s *Store) GetRun(id string) (*model.WorkflowRun, error) {\n   228→\trow := s.db.QueryRow(\n   229→\t\t`SELECT id, workflow_id, status, input, output, current_step,\n   230→\t\t        started_at, completed_at, created_at\n   231→\t\t FROM workflow_runs WHERE id = ?`, id,\n   232→\t)\n   233→\n   234→\tvar r model.WorkflowRun\n   235→\tvar startedAt, completedAt sql.NullTime\n   236→\tif err := row.Scan(\n   237→\t\t&r.ID, &r.WorkflowID, &r.Status, &r.Input, &r.Output, &r.CurrentStep,\n   238→\t\t&startedAt, &completedAt, &r.CreatedAt,\n   239→\t); err != nil {\n   240→\t\tif err == sql.ErrNoRows {\n   241→\t\t\treturn nil, ErrNotFound\n   242→\t\t}\n   243→\t\treturn nil, fmt.Errorf(\"scan run: %w\", err)\n   244→\t}\n   245→\tr.StartedAt = fromNullTime(startedAt)\n   246→\tr.CompletedAt = fromNullTime(completedAt)\n   247→\treturn &r, nil\n   248→}\n   249→\n   250→// ListRuns returns workflow runs, optionally filtered by status. If status is\n   251→// empty, all runs are returned. Results are limited to the given count (0 =\n   252→// no limit).\n   253→func (s *Store) ListRuns(status string, limit int) ([]model.WorkflowRun, error) {\n   254→\tquery := `SELECT id, workflow_id, status, input, output, current_step,\n   255→\t                  started_at, completed_at, created_at\n   256→\t           FROM workflow_runs`\n   257→\tvar args []any\n   258→\n   259→\tif status != \"\" {\n   260→\t\tquery += ` WHERE status = ?`\n   261→\t\targs = append(args, status)\n   262→\t}\n   263→\tquery += ` ORDER BY created_at DESC`\n   264→\tif limit > 0 {\n   265→\t\tquery += fmt.Sprintf(` LIMIT %d`, limit)\n   266→\t}\n   267→\n   268→\trows, err := s.db.Query(query, args...)\n   269→\tif err != nil {\n   270→\t\treturn nil, fmt.Errorf(\"list runs: %w\", err)\n   271→\t}\n   272→\tdefer rows.Close()\n   273→\n   274→\tvar runs []model.WorkflowRun\n   275→\tfor rows.Next() {\n   276→\t\tvar r model.WorkflowRun\n   277→\t\tvar startedAt, completedAt sql.NullTime\n   278→\t\tif err := rows.Scan(\n   279→\t\t\t&r.ID, &r.WorkflowID, &r.Status, &r.Input, &r.Output, &r.CurrentStep,\n   280→\t\t\t&startedAt, &completedAt, &r.CreatedAt,\n   281→\t\t); err != nil {\n   282→\t\t\treturn nil, fmt.Errorf(\"scan run row: %w\", err)\n   283→\t\t}\n   284→\t\tr.StartedAt = fromNullTime(startedAt)\n   285→\t\tr.CompletedAt = fromNullTime(completedAt)\n   286→\t\truns = append(runs, r)\n   287→\t}\n   288→\treturn runs, rows.Err()\n   289→}\n   290→\n   291→// UpdateRun updates a workflow run (all mutable fields).\n   292→func (s *Store) UpdateRun(r *model.WorkflowRun) error {\n   293→\tres, err := s.db.Exec(\n   294→\t\t`UPDATE workflow_runs SET status=?, input=?, output=?, current_step=?,\n   295→\t\t        started_at=?, completed_at=?\n   296→\t\t WHERE id=?`,\n   297→\t\tr.Status, r.Input, r.Output, r.CurrentStep,\n   298→\t\tnullTime(r.StartedAt), nullTime(r.CompletedAt), r.ID,\n   299→\t)\n   300→\tif err != nil {\n   301→\t\treturn fmt.Errorf(\"update run: %w\", err)\n   302→\t}\n   303→\tn, _ := res.RowsAffected()\n   304→\tif n == 0 {\n   305→\t\treturn ErrNotFound\n   306→\t}\n   307→\treturn nil\n   308→}\n   309→\n   310→// ---------------------------------------------------------------------------\n   311→// Activity Runs\n   312→// ---------------------------------------------------------------------------\n   313→\n   314→// CreateActivityRun inserts a new activity run.\n   315→func (s *Store) CreateActivityRun(ar *model.ActivityRun) error {\n   316→\t_, err := s.db.Exec(\n   317→\t\t`INSERT INTO activity_runs\n   318→\t\t   (id, workflow_run_id, activity_name, step_index, status, input, output,\n   319→\t\t    attempts, max_retries, timeout_seconds, started_at, completed_at, last_heartbeat, created_at)\n   320→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   321→\t\tar.ID, ar.WorkflowRunID, ar.ActivityName, ar.StepIndex,\n   322→\t\tar.Status, ar.Input, ar.Output,\n   323→\t\tar.Attempts, ar.MaxRetries, ar.TimeoutSeconds,\n   324→\t\tnullTime(ar.StartedAt), nullTime(ar.CompletedAt), nullTime(ar.LastHeartbeat),\n   325→\t\tar.CreatedAt,\n   326→\t)\n   327→\tif err != nil {\n   328→\t\treturn fmt.Errorf(\"insert activity run: %w\", err)\n   329→\t}\n   330→\treturn nil\n   331→}\n   332→\n   333→// GetActivityRun retrieves an activity run by ID. Returns ErrNotFound if absent.\n   334→func (s *Store) GetActivityRun(id string) (*model.ActivityRun, error) {\n   335→\trow := s.db.QueryRow(\n   336→\t\t`SELECT id, workflow_run_id, activity_name, step_index, status, input, output,\n   337→\t\t        attempts, max_retries, timeout_seconds, started_at, completed_at, last_heartbeat, created_at\n   338→\t\t FROM activity_runs WHERE id = ?`, id,\n   339→\t)\n   340→\treturn scanActivityRun(row)\n   341→}\n   342→\n   343→// GetActivityRunsByRunID returns all activity runs belonging to a workflow run.\n   344→func (s *Store) GetActivityRunsByRunID(runID string) ([]model.ActivityRun, error) {\n   345→\trows, err := s.db.Query(\n   346→\t\t`SELECT id, workflow_run_id, activity_name, step_index, status, input, output,\n   347→\t\t        attempts, max_retries, timeout_seconds, started_at, completed_at, last_heartbeat, created_at\n   348→\t\t FROM activity_runs WHERE workflow_run_id = ? ORDER BY step_index ASC`, runID,\n   349→\t)\n   350→\tif err != nil {\n   351→\t\treturn nil, fmt.Errorf(\"list activity runs: %w\", err)\n   352→\t}\n   353→\tdefer rows.Close()\n   354→\n   355→\tvar ars []model.ActivityRun\n   356→\tfor rows.Next() {\n   357→\t\tvar ar model.ActivityRun\n   358→\t\tvar startedAt, completedAt, lastHeartbeat sql.NullTime\n   359→\t\tif err := rows.Scan(\n   360→\t\t\t&ar.ID, &ar.WorkflowRunID, &ar.ActivityName, &ar.StepIndex,\n   361→\t\t\t&ar.Status, &ar.Input, &ar.Output,\n   362→\t\t\t&ar.Attempts, &ar.MaxRetries, &ar.TimeoutSeconds,\n   363→\t\t\t&startedAt, &completedAt, &lastHeartbeat, &ar.CreatedAt,\n   364→\t\t); err != nil {\n   365→\t\t\treturn nil, fmt.Errorf(\"scan activity run row: %w\", err)\n   366→\t\t}\n   367→\t\tar.StartedAt = fromNullTime(startedAt)\n   368→\t\tar.CompletedAt = fromNullTime(completedAt)\n   369→\t\tar.LastHeartbeat = fromNullTime(lastHeartbeat)\n   370→\t\tars = append(ars, ar)\n   371→\t}\n   372→\treturn ars, rows.Err()\n   373→}\n   374→\n   375→// UpdateActivityRun updates an activity run (all mutable fields).\n   376→func (s *Store) UpdateActivityRun(ar *model.ActivityRun) error {\n   377→\tres, err := s.db.Exec(\n   378→\t\t`UPDATE activity_runs SET status=?, input=?, output=?,\n   379→\t\t        attempts=?, max_retries=?, timeout_seconds=?,\n   380→\t\t        started_at=?, completed_at=?, last_heartbeat=?\n   381→\t\t WHERE id=?`,\n   382→\t\tar.Status, ar.Input, ar.Output,\n   383→\t\tar.Attempts, ar.MaxRetries, ar.TimeoutSeconds,\n   384→\t\tnullTime(ar.StartedAt), nullTime(ar.CompletedAt), nullTime(ar.LastHeartbeat),\n   385→\t\tar.ID,\n   386→\t)\n   387→\tif err != nil {\n   388→\t\treturn fmt.Errorf(\"update activity run: %w\", err)\n   389→\t}\n   390→\tn, _ := res.RowsAffected()\n   391→\tif n == 0 {\n   392→\t\treturn ErrNotFound\n   393→\t}\n   394→\treturn nil\n   395→}\n   396→\n   397→// ClaimNextActivity atomically finds the oldest pending activity run and\n   398→// marks it as running with started_at set to now. Returns (nil, nil) if\n   399→// no pending activity runs exist.\n   400→func (s *Store) ClaimNextActivity() (*model.ActivityRun, error) {\n   401→\ts.claimMu.Lock()\n   402→\tdefer s.claimMu.Unlock()\n   403→\n   404→\ttx, err := s.db.Begin()\n   405→\tif err != nil {\n   406→\t\treturn nil, fmt.Errorf(\"begin tx: %w\", err)\n   407→\t}\n   408→\tdefer tx.Rollback()\n   409→\n   410→\trow := tx.QueryRow(\n   411→\t\t`SELECT id, workflow_run_id, activity_name, step_index, status, input, output,\n   412→\t\t        attempts, max_retries, timeout_seconds, started_at, completed_at, last_heartbeat, created_at\n   413→\t\t FROM activity_runs\n   414→\t\t WHERE status = ?\n   415→\t\t ORDER BY created_at ASC\n   416→\t\t LIMIT 1`,\n   417→\t\tmodel.StatusPending,\n   418→\t)\n   419→\n   420→\tvar ar model.ActivityRun\n   421→\tvar startedAt, completedAt, lastHeartbeat sql.NullTime\n   422→\tif err := row.Scan(\n   423→\t\t&ar.ID, &ar.WorkflowRunID, &ar.ActivityName, &ar.StepIndex,\n   424→\t\t&ar.Status, &ar.Input, &ar.Output,\n   425→\t\t&ar.Attempts, &ar.MaxRetries, &ar.TimeoutSeconds,\n   426→\t\t&startedAt, &completedAt, &lastHeartbeat, &ar.CreatedAt,\n   427→\t); err != nil {\n   428→\t\tif err == sql.ErrNoRows {\n   429→\t\t\treturn nil, nil\n   430→\t\t}\n   431→\t\treturn nil, fmt.Errorf(\"scan claim: %w\", err)\n   432→\t}\n   433→\tar.StartedAt = fromNullTime(startedAt)\n   434→\tar.CompletedAt = fromNullTime(completedAt)\n   435→\tar.LastHeartbeat = fromNullTime(lastHeartbeat)\n   436→\n   437→\tnow := time.Now()\n   438→\tar.Status = model.StatusRunning\n   439→\tar.StartedAt = &now\n   440→\n   441→\t_, err = tx.Exec(\n   442→\t\t`UPDATE activity_runs SET status = ?, started_at = ? WHERE id = ?`,\n   443→\t\tmodel.StatusRunning, now, ar.ID,\n   444→\t)\n   445→\tif err != nil {\n   446→\t\treturn nil, fmt.Errorf(\"update claim: %w\", err)\n   447→\t}\n   448→\n   449→\tif err := tx.Commit(); err != nil {\n   450→\t\treturn nil, fmt.Errorf(\"commit claim: %w\", err)\n   451→\t}\n   452→\treturn &ar, nil\n   453→}\n   454→\n   455→func scanActivityRun(row *sql.Row) (*model.ActivityRun, error) {\n   456→\tvar ar model.ActivityRun\n   457→\tvar startedAt, completedAt, lastHeartbeat sql.NullTime\n   458→\tif err := row.Scan(\n   459→\t\t&ar.ID, &ar.WorkflowRunID, &ar.ActivityName, &ar.StepIndex,\n   460→\t\t&ar.Status, &ar.Input, &ar.Output,\n   461→\t\t&ar.Attempts, &ar.MaxRetries, &ar.TimeoutSeconds,\n   462→\t\t&startedAt, &completedAt, &lastHeartbeat, &ar.CreatedAt,\n   463→\t); err != nil {\n   464→\t\tif err == sql.ErrNoRows {\n   465→\t\t\treturn nil, ErrNotFound\n   466→\t\t}\n   467→\t\treturn nil, fmt.Errorf(\"scan activity run: %w\", err)\n   468→\t}\n   469→\tar.StartedAt = fromNullTime(startedAt)\n   470→\tar.CompletedAt = fromNullTime(completedAt)\n   471→\tar.LastHeartbeat = fromNullTime(lastHeartbeat)\n   472→\treturn &ar, nil\n   473→}\n   474→\n   475→// ---------------------------------------------------------------------------\n   476→// Events\n   477→// ---------------------------------------------------------------------------\n   478→\n   479→// AppendEvent inserts a new event. The ID field is ignored (auto-incremented).\n   480→func (s *Store) AppendEvent(e *model.Event) error {\n   481→\tres, err := s.db.Exec(\n   482→\t\t`INSERT INTO events (workflow_run_id, activity_run_id, event_type, payload, created_at)\n   483→\t\t VALUES (?, ?, ?, ?, ?)`,\n   484→\t\te.WorkflowRunID, nullString(e.ActivityRunID), e.EventType, e.Payload, e.CreatedAt,\n   485→\t)\n   486→\tif err != nil {\n   487→\t\treturn fmt.Errorf(\"insert event: %w\", err)\n   488→\t}\n   489→\tid, _ := res.LastInsertId()\n   490→\te.ID = id\n   491→\treturn nil\n   492→}\n   493→\n   494→// ListEvents returns all events for a given workflow run, ordered by creation.\n   495→func (s *Store) ListEvents(runID string) ([]model.Event, error) {\n   496→\trows, err := s.db.Query(\n   497→\t\t`SELECT id, workflow_run_id, activity_run_id, event_type, payload, created_at\n   498→\t\t FROM events WHERE workflow_run_id = ? ORDER BY id ASC`, runID,\n   499→\t)\n   500→\tif err != nil {\n   501→\t\treturn nil, fmt.Errorf(\"list events: %w\", err)\n   502→\t}\n   503→\tdefer rows.Close()\n   504→\n   505→\tvar events []model.Event\n   506→\tfor rows.Next() {\n   507→\t\tvar ev model.Event\n   508→\t\tvar activityRunID sql.NullString\n   509→\t\tif err := rows.Scan(\n   510→\t\t\t&ev.ID, &ev.WorkflowRunID, &activityRunID,\n   511→\t\t\t&ev.EventType, &ev.Payload, &ev.CreatedAt,\n   512→\t\t); err != nil {\n   513→\t\t\treturn nil, fmt.Errorf(\"scan event: %w\", err)\n   514→\t\t}\n   515→\t\tif activityRunID.Valid {\n   516→\t\t\tev.ActivityRunID = activityRunID.String\n   517→\t\t}\n   518→\t\tevents = append(events, ev)\n   519→\t}\n   520→\treturn events, rows.Err()\n   521→}\n   522→\n   523→// ---------------------------------------------------------------------------\n   524→// Stats\n   525→// ---------------------------------------------------------------------------\n   526→\n   527→// Stats returns a map of workflow run counts grouped by status.\n   528→func (s *Store) Stats() (map[string]int, error) {\n   529→\trows, err := s.db.Query(\n   530→\t\t`SELECT status, COUNT(*) FROM workflow_runs GROUP BY status`,\n   531→\t)\n   532→\tif err != nil {\n   533→\t\treturn nil, fmt.Errorf(\"stats: %w\", err)\n   534→\t}\n   535→\tdefer rows.Close()\n   536→\n   537→\tm := make(map[string]int)\n   538→\tfor rows.Next() {\n   539→\t\tvar status string\n   540→\t\tvar count int\n   541→\t\tif err := rows.Scan(&status, &count); err != nil {\n   542→\t\t\treturn nil, fmt.Errorf(\"scan stats: %w\", err)\n   543→\t\t}\n   544→\t\tm[status] = count\n   545→\t}\n   546→\treturn m, rows.Err()\n   547→}\n   548→\n   549→// ---------------------------------------------------------------------------\n   550→// Helpers\n   551→// ---------------------------------------------------------------------------\n   552→\n   553→// nullTime converts a *time.Time to sql.NullTime for storage.\n   554→func nullTime(t *time.Time) sql.NullTime {\n   555→\tif t == nil {\n   556→\t\treturn sql.NullTime{}\n   557→\t}\n   558→\treturn sql.NullTime{Time: *t, Valid: true}\n   559→}\n   560→\n   561→// fromNullTime converts sql.NullTime back to *time.Time.\n   562→func fromNullTime(nt sql.NullTime) *time.Time {\n   563→\tif !nt.Valid {\n   564→\t\treturn nil\n   565→\t}\n   566→\tt := nt.Time\n   567→\treturn &t\n   568→}\n   569→\n   570→// nullString converts a string to sql.NullString, treating \"\" as NULL.\n   571→func nullString(s string) sql.NullString {\n   572→\tif s == \"\" {\n   573→\t\treturn sql.NullString{}\n   574→\t}\n   575→\treturn sql.NullString{String: s, Valid: true}\n   576→}\n   577→"}]},"parent_tool_use_id":"toolu_01RYc77eg1Vd2uLiYg8Wm6kb","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"647127a6-9863-4cec-b5a5-61c632493342"}
