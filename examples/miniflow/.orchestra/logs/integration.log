{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EQGV3F7QRiefbsxQuNda9H","type":"tool_result","content":"     1→package model\n     2→\n     3→import \"time\"\n     4→\n     5→// ActivitySpec defines a single activity within a workflow definition.\n     6→type ActivitySpec struct {\n     7→\tName           string `json:\"name\"`\n     8→\tType           string `json:\"type\"`\n     9→\tInputExpr      string `json:\"input_expr\"`\n    10→\tTimeoutSeconds int    `json:\"timeout_seconds\"`\n    11→\tMaxRetries     int    `json:\"max_retries\"`\n    12→}\n    13→\n    14→// WorkflowDefinition is the JSON structure stored in workflows.definition.\n    15→type WorkflowDefinition struct {\n    16→\tActivities []ActivitySpec `json:\"activities\"`\n    17→}\n    18→\n    19→// Workflow represents a registered workflow template.\n    20→type Workflow struct {\n    21→\tID         string             `json:\"id\"`\n    22→\tName       string             `json:\"name\"`\n    23→\tDefinition WorkflowDefinition `json:\"definition\"`\n    24→\tCreatedAt  time.Time          `json:\"created_at\"`\n    25→}\n    26→"}]},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"e1a457f1-6160-4f33-bb9e-da1d620794ce"}
