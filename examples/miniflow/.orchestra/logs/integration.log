{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016TsiTW6PGLehCftc1xffjz","type":"tool_result","content":"     1→package activity\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"sync\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"miniflow/internal/model\"\n    11→)\n    12→\n    13→// mockStore implements ActivityStore for testing.\n    14→type mockStore struct {\n    15→\tmu          sync.Mutex\n    16→\tactivities  []*model.ActivityRun\n    17→\tevents      []*model.Event\n    18→\tclaimed     map[string]bool\n    19→\treclaimable bool // if true, activities set back to pending can be re-claimed\n    20→}\n    21→\n    22→func newMockStore() *mockStore {\n    23→\treturn &mockStore{\n    24→\t\tclaimed: make(map[string]bool),\n    25→\t}\n    26→}\n    27→\n    28→func (m *mockStore) AddActivity(ar *model.ActivityRun) {\n    29→\tm.mu.Lock()\n    30→\tdefer m.mu.Unlock()\n    31→\tm.activities = append(m.activities, ar)\n    32→}\n    33→\n    34→func (m *mockStore) ClaimNextActivity() (*model.ActivityRun, error) {\n    35→\tm.mu.Lock()\n    36→\tdefer m.mu.Unlock()\n    37→\tfor _, ar := range m.activities {\n    38→\t\tif ar.Status == model.StatusPending && !m.claimed[ar.ID] {\n    39→\t\t\tm.claimed[ar.ID] = true\n    40→\t\t\treturn ar, nil\n    41→\t\t}\n    42→\t}\n    43→\treturn nil, nil\n    44→}\n    45→\n    46→func (m *mockStore) UpdateActivityRun(ar *model.ActivityRun) error {\n    47→\tm.mu.Lock()\n    48→\tdefer m.mu.Unlock()\n    49→\t// If set back to pending and reclaimable, allow re-claiming.\n    50→\tif ar.Status == model.StatusPending && m.reclaimable {\n    51→\t\tdelete(m.claimed, ar.ID)\n    52→\t}\n    53→\treturn nil\n    54→}\n    55→\n    56→func (m *mockStore) AppendEvent(e *model.Event) error {\n    57→\tm.mu.Lock()\n    58→\tdefer m.mu.Unlock()\n    59→\tm.events = append(m.events, e)\n    60→\treturn nil\n    61→}\n    62→\n    63→func (m *mockStore) getActivity(id string) *model.ActivityRun {\n    64→\tm.mu.Lock()\n    65→\tdefer m.mu.Unlock()\n    66→\tfor _, ar := range m.activities {\n    67→\t\tif ar.ID == id {\n    68→\t\t\treturn ar\n    69→\t\t}\n    70→\t}\n    71→\treturn nil\n    72→}\n    73→\n    74→func (m *mockStore) getEvents() []*model.Event {\n    75→\tm.mu.Lock()\n    76→\tdefer m.mu.Unlock()\n    77→\tcp := make([]*model.Event, len(m.events))\n    78→\tcopy(cp, m.events)\n    79→\treturn cp\n    80→}\n    81→\n    82→// --- Registry tests ---\n    83→\n    84→func TestRegistry_ExecuteUnknown(t *testing.T) {\n    85→\tr := NewRegistry()\n    86→\t_, err := r.Execute(context.Background(), \"nonexistent\", \"\")\n    87→\tif err == nil {\n    88→\t\tt.Fatal(\"expected error for unregistered activity, got nil\")\n    89→\t}\n    90→}\n    91→\n    92→// --- Builtin tests ---\n    93→\n    94→func TestBuiltinNoop(t *testing.T) {\n    95→\tr := NewRegistry()\n    96→\tRegisterBuiltins(r)\n    97→\tout, err := r.Execute(context.Background(), \"noop\", \"hello\")\n    98→\tif err != nil {\n    99→\t\tt.Fatalf(\"unexpected error: %v\", err)\n   100→\t}\n   101→\tif out != \"hello\" {\n   102→\t\tt.Fatalf(\"expected 'hello', got %q\", out)\n   103→\t}\n   104→}\n   105→\n   106→func TestBuiltinSleep(t *testing.T) {\n   107→\tr := NewRegistry()\n   108→\tRegisterBuiltins(r)\n   109→\tout, err := r.Execute(context.Background(), \"sleep\", `{\"duration_ms\": 10}`)\n   110→\tif err != nil {\n   111→\t\tt.Fatalf(\"unexpected error: %v\", err)\n   112→\t}\n   113→\tvar result struct {\n   114→\t\tSlept int `json:\"slept\"`\n   115→\t}\n   116→\tif err := json.Unmarshal([]byte(out), &result); err != nil {\n   117→\t\tt.Fatalf(\"invalid output json: %v\", err)\n   118→\t}\n   119→\tif result.Slept != 10 {\n   120→\t\tt.Fatalf(\"expected slept=10, got %d\", result.Slept)\n   121→\t}\n   122→}\n   123→\n   124→func TestBuiltinLog(t *testing.T) {\n   125→\tr := NewRegistry()\n   126→\tRegisterBuiltins(r)\n   127→\tout, err := r.Execute(context.Background(), \"log\", `{\"message\": \"test msg\"}`)\n   128→\tif err != nil {\n   129→\t\tt.Fatalf(\"unexpected error: %v\", err)\n   130→\t}\n   131→\tvar result struct {\n   132→\t\tLogged bool `json:\"logged\"`\n   133→\t}\n   134→\tif err := json.Unmarshal([]byte(out), &result); err != nil {\n   135→\t\tt.Fatalf(\"invalid output json: %v\", err)\n   136→\t}\n   137→\tif !result.Logged {\n   138→\t\tt.Fatal(\"expected logged=true\")\n   139→\t}\n   140→}\n   141→\n   142→func TestBuiltinFail(t *testing.T) {\n   143→\tr := NewRegistry()\n   144→\tRegisterBuiltins(r)\n   145→\t_, err := r.Execute(context.Background(), \"fail\", \"\")\n   146→\tif err == nil {\n   147→\t\tt.Fatal(\"expected error from fail handler, got nil\")\n   148→\t}\n   149→\tif err.Error() != \"activity failed\" {\n   150→\t\tt.Fatalf(\"expected 'activity failed', got %q\", err.Error())\n   151→\t}\n   152→}\n   153→\n   154→// --- Worker tests ---\n   155→\n   156→func TestWorkerSuccessfulExecution(t *testing.T) {\n   157→\tstore := newMockStore()\n   158→\treg := NewRegistry()\n   159→\tRegisterBuiltins(reg)\n   160→\n   161→\tar := &model.ActivityRun{\n   162→\t\tID:             \"ar-1\",\n   163→\t\tWorkflowRunID:  \"wr-1\",\n   164→\t\tActivityName:   \"noop\",\n   165→\t\tStatus:         model.StatusPending,\n   166→\t\tInput:          \"test-input\",\n   167→\t\tMaxRetries:     3,\n   168→\t\tTimeoutSeconds: 10,\n   169→\t\tCreatedAt:      time.Now(),\n   170→\t}\n   171→\tstore.AddActivity(ar)\n   172→\n   173→\twp := NewWorkerPool(store, reg, 1, 10*time.Millisecond)\n   174→\twp.Start()\n   175→\ttime.Sleep(200 * time.Millisecond)\n   176→\twp.Stop()\n   177→\n   178→\tact := store.getActivity(\"ar-1\")\n   179→\tif act.Status != model.StatusCompleted {\n   180→\t\tt.Fatalf(\"expected status completed, got %s\", act.Status)\n   181→\t}\n   182→\tif act.Output != \"test-input\" {\n   183→\t\tt.Fatalf(\"expected output 'test-input', got %q\", act.Output)\n   184→\t}\n   185→\tif act.Attempts != 1 {\n   186→\t\tt.Fatalf(\"expected attempts=1, got %d\", act.Attempts)\n   187→\t}\n   188→\n   189→\tevents := store.getEvents()\n   190→\thasStarted := false\n   191→\thasCompleted := false\n   192→\tfor _, e := range events {\n   193→\t\tif e.EventType == model.EventActivityStarted {\n   194→\t\t\thasStarted = true\n   195→\t\t}\n   196→\t\tif e.EventType == model.EventActivityCompleted {\n   197→\t\t\thasCompleted = true\n   198→\t\t}\n   199→\t}\n   200→\tif !hasStarted {\n   201→\t\tt.Fatal(\"expected activity_started event\")\n   202→\t}\n   203→\tif !hasCompleted {\n   204→\t\tt.Fatal(\"expected activity_completed event\")\n   205→\t}\n   206→}\n   207→\n   208→func TestWorkerFailureAndRetry(t *testing.T) {\n   209→\tstore := newMockStore()\n   210→\treg := NewRegistry()\n   211→\tRegisterBuiltins(reg)\n   212→\n   213→\tar := &model.ActivityRun{\n   214→\t\tID:             \"ar-2\",\n   215→\t\tWorkflowRunID:  \"wr-2\",\n   216→\t\tActivityName:   \"fail\",\n   217→\t\tStatus:         model.StatusPending,\n   218→\t\tInput:          \"\",\n   219→\t\tAttempts:       0,\n   220→\t\tMaxRetries:     3,\n   221→\t\tTimeoutSeconds: 10,\n   222→\t\tCreatedAt:      time.Now(),\n   223→\t}\n   224→\tstore.AddActivity(ar)\n   225→\n   226→\twp := NewWorkerPool(store, reg, 1, 10*time.Millisecond)\n   227→\twp.Start()\n   228→\ttime.Sleep(200 * time.Millisecond)\n   229→\twp.Stop()\n   230→\n   231→\tact := store.getActivity(\"ar-2\")\n   232→\tif act.Status != model.StatusPending {\n   233→\t\tt.Fatalf(\"expected status pending (for retry), got %s\", act.Status)\n   234→\t}\n   235→\tif act.Attempts != 1 {\n   236→\t\tt.Fatalf(\"expected attempts=1 after first failure, got %d\", act.Attempts)\n   237→\t}\n   238→\n   239→\tevents := store.getEvents()\n   240→\thasRetried := false\n   241→\tfor _, e := range events {\n   242→\t\tif e.EventType == model.EventActivityRetried {\n   243→\t\t\thasRetried = true\n   244→\t\t}\n   245→\t}\n   246→\tif !hasRetried {\n   247→\t\tt.Fatal(\"expected activity_retried event\")\n   248→\t}\n   249→}\n   250→\n   251→func TestWorkerMaxRetriesExhausted(t *testing.T) {\n   252→\tstore := newMockStore()\n   253→\treg := NewRegistry()\n   254→\tRegisterBuiltins(reg)\n   255→\n   256→\tar := &model.ActivityRun{\n   257→\t\tID:             \"ar-3\",\n   258→\t\tWorkflowRunID:  \"wr-3\",\n   259→\t\tActivityName:   \"fail\",\n   260→\t\tStatus:         model.StatusPending,\n   261→\t\tInput:          \"\",\n   262→\t\tAttempts:       2,\n   263→\t\tMaxRetries:     3,\n   264→\t\tTimeoutSeconds: 10,\n   265→\t\tCreatedAt:      time.Now(),\n   266→\t}\n   267→\tstore.AddActivity(ar)\n   268→\n   269→\twp := NewWorkerPool(store, reg, 1, 10*time.Millisecond)\n   270→\twp.Start()\n   271→\ttime.Sleep(200 * time.Millisecond)\n   272→\twp.Stop()\n   273→\n   274→\tact := store.getActivity(\"ar-3\")\n   275→\tif act.Status != model.StatusFailed {\n   276→\t\tt.Fatalf(\"expected status failed, got %s\", act.Status)\n   277→\t}\n   278→\tif act.Attempts != 3 {\n   279→\t\tt.Fatalf(\"expected attempts=3, got %d\", act.Attempts)\n   280→\t}\n   281→\n   282→\tevents := store.getEvents()\n   283→\thasFailed := false\n   284→\tfor _, e := range events {\n   285→\t\tif e.EventType == model.EventActivityFailed {\n   286→\t\t\thasFailed = true\n   287→\t\t}\n   288→\t}\n   289→\tif !hasFailed {\n   290→\t\tt.Fatal(\"expected activity_failed event\")\n   291→\t}\n   292→}\n   293→"}]},"parent_tool_use_id":"toolu_01NHF3R5g7kdFioUm6bPGqQp","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"2ab9e1a4-ea2c-4bf6-b847-a1cb2bf3fd47"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011gJJxUTksPuHGMTbNboG2Q","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01N1HjZFZRQ9yWmikrrprpUv","name":"Write","input":{"file_path":"/Users/michaelhabib/dev/teams-sbx/agent-orchestra/examples/miniflow/tests/workflow_test.go","content":"package tests\n\nimport (\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"miniflow/internal/client\"\n)\n\nfunc TestRegisterAndListWorkflows(t *testing.T) {\n\tenv := newTestEnv(t)\n\n\tregisterTestWorkflow(t, env.client, \"workflow-a\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t))\n\tregisterTestWorkflow(t, env.client, \"workflow-b\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t\tclient.ActivitySpec{Name: \"log\", Type: \"log\"},\n\t))\n\n\tworkflows, err := env.client.ListWorkflows()\n\tif err != nil {\n\t\tt.Fatalf(\"ListWorkflows failed: %v\", err)\n\t}\n\tif len(workflows) != 2 {\n\t\tt.Fatalf(\"expected 2 workflows, got %d\", len(workflows))\n\t}\n\n\tnames := map[string]bool{}\n\tfor _, wf := range workflows {\n\t\tnames[wf.Name] = true\n\t}\n\tif !names[\"workflow-a\"] {\n\t\tt.Error(\"workflow-a not found in list\")\n\t}\n\tif !names[\"workflow-b\"] {\n\t\tt.Error(\"workflow-b not found in list\")\n\t}\n}\n\nfunc TestSimpleWorkflowExecution(t *testing.T) {\n\tenv := newTestEnvWithWorkers(t, 2)\n\n\tregisterTestWorkflow(t, env.client, \"simple-wf\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t))\n\n\trun, err := env.client.StartRun(\"simple-wf\", \"{}\")\n\tif err != nil {\n\t\tt.Fatalf(\"StartRun failed: %v\", err)\n\t}\n\n\twaitForRunStatus(t, env.client, run.ID, \"completed\", 5*time.Second)\n\n\tdetail, err := env.client.GetRun(run.ID)\n\tif err != nil {\n\t\tt.Fatalf(\"GetRun failed: %v\", err)\n\t}\n\tif len(detail.Activities) != 2 {\n\t\tt.Fatalf(\"expected 2 activities, got %d\", len(detail.Activities))\n\t}\n\tfor i, act := range detail.Activities {\n\t\tif act.Status != \"completed\" {\n\t\t\tt.Errorf(\"activity %d status = %q, want %q\", i, act.Status, \"completed\")\n\t\t}\n\t}\n}\n\nfunc TestWorkflowWithDataPassing(t *testing.T) {\n\tenv := newTestEnvWithWorkers(t, 2)\n\n\tregisterTestWorkflow(t, env.client, \"data-passing-wf\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\", InputExpr: \"$.input\"},\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\", InputExpr: \"$.steps[0].output\"},\n\t))\n\n\trun, err := env.client.StartRun(\"data-passing-wf\", `{\"value\":\"hello\"}`)\n\tif err != nil {\n\t\tt.Fatalf(\"StartRun failed: %v\", err)\n\t}\n\n\twaitForRunStatus(t, env.client, run.ID, \"completed\", 5*time.Second)\n\n\tdetail, err := env.client.GetRun(run.ID)\n\tif err != nil {\n\t\tt.Fatalf(\"GetRun failed: %v\", err)\n\t}\n\tif len(detail.Activities) != 2 {\n\t\tt.Fatalf(\"expected 2 activities, got %d\", len(detail.Activities))\n\t}\n\t// noop passes input through as output, so step2's output should contain \"hello\"\n\tif !strings.Contains(detail.Activities[1].Output, \"hello\") {\n\t\tt.Errorf(\"step2 output %q does not contain %q\", detail.Activities[1].Output, \"hello\")\n\t}\n}\n\nfunc TestMultiStepWorkflow(t *testing.T) {\n\tenv := newTestEnvWithWorkers(t, 2)\n\n\tregisterTestWorkflow(t, env.client, \"multi-step-wf\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t\tclient.ActivitySpec{Name: \"sleep\", Type: \"sleep\"},\n\t\tclient.ActivitySpec{Name: \"log\", Type: \"log\"},\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t))\n\n\t// Provide input that satisfies sleep (duration_ms) and log (message)\n\trun, err := env.client.StartRun(\"multi-step-wf\", `{\"duration_ms\":10,\"message\":\"test\"}`)\n\tif err != nil {\n\t\tt.Fatalf(\"StartRun failed: %v\", err)\n\t}\n\n\twaitForRunStatus(t, env.client, run.ID, \"completed\", 10*time.Second)\n\n\tdetail, err := env.client.GetRun(run.ID)\n\tif err != nil {\n\t\tt.Fatalf(\"GetRun failed: %v\", err)\n\t}\n\tif len(detail.Activities) != 4 {\n\t\tt.Fatalf(\"expected 4 activities, got %d\", len(detail.Activities))\n\t}\n\tfor i, act := range detail.Activities {\n\t\tif act.Status != \"completed\" {\n\t\t\tt.Errorf(\"activity %d (%s) status = %q, want %q\", i, act.ActivityName, act.Status, \"completed\")\n\t\t}\n\t}\n}\n\nfunc TestRunWithInput(t *testing.T) {\n\tenv := newTestEnvWithWorkers(t, 2)\n\n\tregisterTestWorkflow(t, env.client, \"input-wf\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t))\n\n\tcustomInput := `{\"key\":\"custom_value\"}`\n\trun, err := env.client.StartRun(\"input-wf\", customInput)\n\tif err != nil {\n\t\tt.Fatalf(\"StartRun failed: %v\", err)\n\t}\n\n\twaitForRunStatus(t, env.client, run.ID, \"completed\", 5*time.Second)\n\n\tdetail, err := env.client.GetRun(run.ID)\n\tif err != nil {\n\t\tt.Fatalf(\"GetRun failed: %v\", err)\n\t}\n\tif !strings.Contains(detail.Input, \"custom_value\") {\n\t\tt.Errorf(\"run input %q does not contain %q\", detail.Input, \"custom_value\")\n\t}\n}\n\nfunc TestListRunsFiltered(t *testing.T) {\n\tenv := newTestEnvWithWorkers(t, 2)\n\n\tregisterTestWorkflow(t, env.client, \"list-runs-wf\", sampleWorkflow(\n\t\tclient.ActivitySpec{Name: \"noop\", Type: \"noop\"},\n\t))\n\n\tvar runIDs []string\n\tfor i := 0; i < 3; i++ {\n\t\trun, err := env.client.StartRun(\"list-runs-wf\", \"{}\")\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"StartRun %d failed: %v\", i, err)\n\t\t}\n\t\trunIDs = append(runIDs, run.ID)\n\t}\n\n\tfor _, id := range runIDs {\n\t\twaitForRunStatus(t, env.client, id, \"completed\", 5*time.Second)\n\t}\n\n\t// List all runs\n\tallRuns, err := env.client.ListRuns(\"\", 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListRuns (all) failed: %v\", err)\n\t}\n\tif len(allRuns) < 3 {\n\t\tt.Errorf(\"expected at least 3 runs, got %d\", len(allRuns))\n\t}\n\n\t// List completed runs\n\tcompletedRuns, err := env.client.ListRuns(\"completed\", 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListRuns (completed) failed: %v\", err)\n\t}\n\tif len(completedRuns) < 3 {\n\t\tt.Errorf(\"expected at least 3 completed runs, got %d\", len(completedRuns))\n\t}\n\n\t// List pending runs (should be 0 since all completed)\n\tpendingRuns, err := env.client.ListRuns(\"pending\", 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListRuns (pending) failed: %v\", err)\n\t}\n\tif len(pendingRuns) != 0 {\n\t\tt.Errorf(\"expected 0 pending runs, got %d\", len(pendingRuns))\n\t}\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1346,"cache_read_input_tokens":45429,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1346},"output_tokens":26,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01RYc77eg1Vd2uLiYg8Wm6kb","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"11d50fee-4efd-4a8a-988a-7d4ee5503779"}
