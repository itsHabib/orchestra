{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XkMMiGP1KKGUV3nRzFgWP3","type":"tool_result","content":"     1→package tests\n     2→\n     3→import (\n     4→\t\"net/http\"\n     5→\t\"net/http/httptest\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"miniflow/internal/activity\"\n    11→\t\"miniflow/internal/client\"\n    12→\t\"miniflow/internal/executor\"\n    13→\t\"miniflow/internal/handler\"\n    14→\t\"miniflow/internal/store\"\n    15→)\n    16→\n    17→// testEnv holds all components needed for integration tests.\n    18→type testEnv struct {\n    19→\tstore      *store.Store\n    20→\thandler    http.Handler\n    21→\tserver     *httptest.Server\n    22→\tclient     *client.Client\n    23→\texecutor   *executor.Executor\n    24→\tscheduler  *executor.Scheduler\n    25→\tworkerPool *activity.WorkerPool\n    26→}\n    27→\n    28→// newTestEnv creates a test environment with store, executor, handler, httptest\n    29→// server, and client. No workers or scheduler are started.\n    30→func newTestEnv(t *testing.T) *testEnv {\n    31→\tt.Helper()\n    32→\n    33→\tdbPath := filepath.Join(t.TempDir(), \"test.db\")\n    34→\ts, err := store.NewStore(dbPath)\n    35→\tif err != nil {\n    36→\t\tt.Fatalf(\"failed to create store: %v\", err)\n    37→\t}\n    38→\n    39→\tex := executor.NewExecutor(s)\n    40→\th := handler.New(s, ex)\n    41→\tsrv := httptest.NewServer(h)\n    42→\tc := client.NewClient(srv.URL)\n    43→\n    44→\tenv := &testEnv{\n    45→\t\tstore:    s,\n    46→\t\thandler:  h,\n    47→\t\tserver:   srv,\n    48→\t\tclient:   c,\n    49→\t\texecutor: ex,\n    50→\t}\n    51→\n    52→\tt.Cleanup(func() {\n    53→\t\tsrv.Close()\n    54→\t\ts.Close()\n    55→\t})\n    56→\n    57→\treturn env\n    58→}\n    59→\n    60→// newTestEnvWithWorkers creates a test environment with workers and scheduler running.\n    61→func newTestEnvWithWorkers(t *testing.T, count int) *testEnv {\n    62→\tt.Helper()\n    63→\n    64→\tdbPath := filepath.Join(t.TempDir(), \"test.db\")\n    65→\ts, err := store.NewStore(dbPath)\n    66→\tif err != nil {\n    67→\t\tt.Fatalf(\"failed to create store: %v\", err)\n    68→\t}\n    69→\n    70→\tex := executor.NewExecutor(s)\n    71→\th := handler.New(s, ex)\n    72→\tsrv := httptest.NewServer(h)\n    73→\tc := client.NewClient(srv.URL)\n    74→\n    75→\tregistry := activity.NewRegistry()\n    76→\tactivity.RegisterBuiltins(registry)\n    77→\n    78→\twp := activity.NewWorkerPool(s, registry, count, 50*time.Millisecond)\n    79→\twp.Start()\n    80→\n    81→\tsched := executor.NewScheduler(ex, s, 50*time.Millisecond)\n    82→\tsched.Start()\n    83→\n    84→\tenv := &testEnv{\n    85→\t\tstore:      s,\n    86→\t\thandler:    h,\n    87→\t\tserver:     srv,\n    88→\t\tclient:     c,\n    89→\t\texecutor:   ex,\n    90→\t\tscheduler:  sched,\n    91→\t\tworkerPool: wp,\n    92→\t}\n    93→\n    94→\tt.Cleanup(func() {\n    95→\t\tsched.Stop()\n    96→\t\twp.Stop()\n    97→\t\tsrv.Close()\n    98→\t\ts.Close()\n    99→\t})\n   100→\n   101→\treturn env\n   102→}\n   103→\n   104→// registerTestWorkflow registers a workflow via the client, fataling on error.\n   105→func registerTestWorkflow(t *testing.T, c *client.Client, name string, activities []client.ActivitySpec) *client.Workflow {\n   106→\tt.Helper()\n   107→\twf, err := c.RegisterWorkflow(name, client.WorkflowDefinition{\n   108→\t\tActivities: activities,\n   109→\t})\n   110→\tif err != nil {\n   111→\t\tt.Fatalf(\"failed to register workflow %q: %v\", name, err)\n   112→\t}\n   113→\treturn wf\n   114→}\n   115→\n   116→// waitForRunStatus polls GetRun every 50ms until the run reaches the expected\n   117→// status or the timeout expires.\n   118→func waitForRunStatus(t *testing.T, c *client.Client, runID string, status string, timeout time.Duration) {\n   119→\tt.Helper()\n   120→\tdeadline := time.Now().Add(timeout)\n   121→\tfor time.Now().Before(deadline) {\n   122→\t\trun, err := c.GetRun(runID)\n   123→\t\tif err != nil {\n   124→\t\t\tt.Fatalf(\"failed to get run %s: %v\", runID, err)\n   125→\t\t}\n   126→\t\tif run.Status == status {\n   127→\t\t\treturn\n   128→\t\t}\n   129→\t\ttime.Sleep(50 * time.Millisecond)\n   130→\t}\n   131→\tt.Fatalf(\"timed out waiting for run %s to reach status %q\", runID, status)\n   132→}\n   133→\n   134→// sampleWorkflow is a convenience function that returns the given activity specs as a slice.\n   135→func sampleWorkflow(specs ...client.ActivitySpec) []client.ActivitySpec {\n   136→\treturn specs\n   137→}\n   138→"}]},"parent_tool_use_id":"toolu_01NHF3R5g7kdFioUm6bPGqQp","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"f856dbf3-bea7-4800-9505-05c20f992997"}
