{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WQyNQqEZWPKGsFEGsoqckq","type":"tool_result","content":"     1→package store\n     2→\n     3→import \"errors\"\n     4→\n     5→// Sentinel errors returned by Store methods.\n     6→var (\n     7→\t// ErrNotFound is returned when a requested entity does not exist.\n     8→\tErrNotFound = errors.New(\"not found\")\n     9→\n    10→\t// ErrDuplicateWorkflow is returned when creating a workflow with a name\n    11→\t// that already exists (UNIQUE constraint violation).\n    12→\tErrDuplicateWorkflow = errors.New(\"duplicate workflow name\")\n    13→)\n    14→"}]},"parent_tool_use_id":"toolu_017DaC9TpQABNBwJVFEELshq","session_id":"701e3a6a-36af-4762-8d76-051700988d74","uuid":"721f1898-a0b8-407b-8e9e-41ee355cc757"}
