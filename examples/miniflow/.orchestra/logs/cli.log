{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WrmAHvBD7cbnhcbcLTZ9JN","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"log\"\n     6→\t\"net/http\"\n     7→\t\"os\"\n     8→\t\"os/signal\"\n     9→\t\"syscall\"\n    10→\t\"time\"\n    11→\n    12→\t\"miniflow/internal/activity\"\n    13→\t\"miniflow/internal/config\"\n    14→\t\"miniflow/internal/executor\"\n    15→\t\"miniflow/internal/handler\"\n    16→\t\"miniflow/internal/store\"\n    17→)\n    18→\n    19→func main() {\n    20→\tcfg := config.Load()\n    21→\n    22→\ts, err := store.NewStore(cfg.DBPath)\n    23→\tif err != nil {\n    24→\t\tlog.Fatalf(\"failed to open store: %v\", err)\n    25→\t}\n    26→\tdefer s.Close()\n    27→\n    28→\t// Activity registry with built-in handlers.\n    29→\tregistry := activity.NewRegistry()\n    30→\tactivity.RegisterBuiltins(registry)\n    31→\n    32→\t// Activity worker pool.\n    33→\tworkers := activity.NewWorkerPool(s, registry, cfg.WorkerCount, 500*time.Millisecond)\n    34→\tworkers.Start()\n    35→\n    36→\t// Workflow executor and scheduler.\n    37→\tex := executor.NewExecutor(s)\n    38→\tsched := executor.NewScheduler(ex, s, 500*time.Millisecond)\n    39→\tsched.Start()\n    40→\n    41→\t// HTTP server.\n    42→\trouter := handler.New(s, ex)\n    43→\tsrv := &http.Server{\n    44→\t\tAddr:    \":\" + cfg.Port,\n    45→\t\tHandler: router,\n    46→\t}\n    47→\n    48→\t// Graceful shutdown.\n    49→\tquit := make(chan os.Signal, 1)\n    50→\tsignal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)\n    51→\n    52→\tgo func() {\n    53→\t\tlog.Printf(\"miniflow server listening on :%s\", cfg.Port)\n    54→\t\tif err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n    55→\t\t\tlog.Fatalf(\"server error: %v\", err)\n    56→\t\t}\n    57→\t}()\n    58→\n    59→\t<-quit\n    60→\tlog.Println(\"shutting down...\")\n    61→\n    62→\tsched.Stop()\n    63→\tworkers.Stop()\n    64→\n    65→\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    66→\tdefer cancel()\n    67→\tif err := srv.Shutdown(ctx); err != nil {\n    68→\t\tlog.Fatalf(\"server shutdown error: %v\", err)\n    69→\t}\n    70→\tlog.Println(\"miniflow stopped\")\n    71→}\n    72→"}]},"parent_tool_use_id":"toolu_01PjP1ptV6pqXyqjLTjeuXaV","session_id":"f8753322-d9f7-4d57-9d3d-95109e75f16d","uuid":"441b1bee-21ea-45da-a09d-8524e0c86902"}
