{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AhDrKWkkxZtdp271KyeqGZ","type":"tool_result","content":"     1→package executor\n     2→\n     3→import (\n     4→\t\"log\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→// Scheduler periodically polls the store for pending and running workflow\n     9→// runs and drives them forward via the Executor.\n    10→type Scheduler struct {\n    11→\texecutor *Executor\n    12→\tstore    RunStore\n    13→\tinterval time.Duration\n    14→\tquit     chan struct{}\n    15→}\n    16→\n    17→// NewScheduler creates a Scheduler that ticks at the given interval.\n    18→func NewScheduler(executor *Executor, store RunStore, interval time.Duration) *Scheduler {\n    19→\treturn &Scheduler{\n    20→\t\texecutor: executor,\n    21→\t\tstore:    store,\n    22→\t\tinterval: interval,\n    23→\t\tquit:     make(chan struct{}),\n    24→\t}\n    25→}\n    26→\n    27→// Start begins polling in a background goroutine.\n    28→func (s *Scheduler) Start() {\n    29→\tgo s.loop()\n    30→}\n    31→\n    32→// Stop signals the polling goroutine to exit and returns immediately.\n    33→func (s *Scheduler) Stop() {\n    34→\tclose(s.quit)\n    35→}\n    36→\n    37→func (s *Scheduler) loop() {\n    38→\tticker := time.NewTicker(s.interval)\n    39→\tdefer ticker.Stop()\n    40→\n    41→\tfor {\n    42→\t\tselect {\n    43→\t\tcase <-s.quit:\n    44→\t\t\treturn\n    45→\t\tcase <-ticker.C:\n    46→\t\t\ts.tick()\n    47→\t\t}\n    48→\t}\n    49→}\n    50→\n    51→func (s *Scheduler) tick() {\n    52→\t// Start any pending runs.\n    53→\tpending, err := s.store.ListRuns(\"pending\", 100)\n    54→\tif err != nil {\n    55→\t\tlog.Printf(\"scheduler: list pending runs: %v\", err)\n    56→\t} else {\n    57→\t\tfor _, run := range pending {\n    58→\t\t\tif err := s.executor.StartRun(run.ID); err != nil {\n    59→\t\t\t\tlog.Printf(\"scheduler: start run %s: %v\", run.ID, err)\n    60→\t\t\t}\n    61→\t\t}\n    62→\t}\n    63→\n    64→\t// Advance any running runs.\n    65→\trunning, err := s.store.ListRuns(\"running\", 100)\n    66→\tif err != nil {\n    67→\t\tlog.Printf(\"scheduler: list running runs: %v\", err)\n    68→\t} else {\n    69→\t\tfor _, run := range running {\n    70→\t\t\tif err := s.executor.AdvanceRun(run.ID); err != nil {\n    71→\t\t\t\tlog.Printf(\"scheduler: advance run %s: %v\", run.ID, err)\n    72→\t\t\t}\n    73→\t\t}\n    74→\t}\n    75→}\n    76→"}]},"parent_tool_use_id":null,"session_id":"60911857-bac5-4e5c-815c-3e677cf891bd","uuid":"160ebaeb-99e7-4924-91da-709795658ea1","tool_use_result":{"type":"text","file":{"filePath":"/Users/michaelhabib/dev/teams-sbx/agent-orchestra/examples/miniflow/internal/executor/scheduler.go","content":"package executor\n\nimport (\n\t\"log\"\n\t\"time\"\n)\n\n// Scheduler periodically polls the store for pending and running workflow\n// runs and drives them forward via the Executor.\ntype Scheduler struct {\n\texecutor *Executor\n\tstore    RunStore\n\tinterval time.Duration\n\tquit     chan struct{}\n}\n\n// NewScheduler creates a Scheduler that ticks at the given interval.\nfunc NewScheduler(executor *Executor, store RunStore, interval time.Duration) *Scheduler {\n\treturn &Scheduler{\n\t\texecutor: executor,\n\t\tstore:    store,\n\t\tinterval: interval,\n\t\tquit:     make(chan struct{}),\n\t}\n}\n\n// Start begins polling in a background goroutine.\nfunc (s *Scheduler) Start() {\n\tgo s.loop()\n}\n\n// Stop signals the polling goroutine to exit and returns immediately.\nfunc (s *Scheduler) Stop() {\n\tclose(s.quit)\n}\n\nfunc (s *Scheduler) loop() {\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-s.quit:\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\ts.tick()\n\t\t}\n\t}\n}\n\nfunc (s *Scheduler) tick() {\n\t// Start any pending runs.\n\tpending, err := s.store.ListRuns(\"pending\", 100)\n\tif err != nil {\n\t\tlog.Printf(\"scheduler: list pending runs: %v\", err)\n\t} else {\n\t\tfor _, run := range pending {\n\t\t\tif err := s.executor.StartRun(run.ID); err != nil {\n\t\t\t\tlog.Printf(\"scheduler: start run %s: %v\", run.ID, err)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Advance any running runs.\n\trunning, err := s.store.ListRuns(\"running\", 100)\n\tif err != nil {\n\t\tlog.Printf(\"scheduler: list running runs: %v\", err)\n\t} else {\n\t\tfor _, run := range running {\n\t\t\tif err := s.executor.AdvanceRun(run.ID); err != nil {\n\t\t\t\tlog.Printf(\"scheduler: advance run %s: %v\", run.ID, err)\n\t\t\t}\n\t\t}\n\t}\n}\n","numLines":76,"startLine":1,"totalLines":76}}}
