{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J9RbacLLLkkf53ukMBWs3P","type":"tool_result","content":"     1→package activity\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→)\n     8→\n     9→// HandlerFunc is the signature for activity handlers.\n    10→type HandlerFunc func(ctx context.Context, input string) (string, error)\n    11→\n    12→// Registry holds registered activity handlers.\n    13→type Registry struct {\n    14→\tmu       sync.RWMutex\n    15→\thandlers map[string]HandlerFunc\n    16→}\n    17→\n    18→// NewRegistry creates a new empty Registry.\n    19→func NewRegistry() *Registry {\n    20→\treturn &Registry{\n    21→\t\thandlers: make(map[string]HandlerFunc),\n    22→\t}\n    23→}\n    24→\n    25→// Register adds a handler for the given activity name.\n    26→func (r *Registry) Register(name string, handler HandlerFunc) {\n    27→\tr.mu.Lock()\n    28→\tdefer r.mu.Unlock()\n    29→\tr.handlers[name] = handler\n    30→}\n    31→\n    32→// Execute runs the handler registered under the given name.\n    33→// It returns an error if no handler is registered for that name.\n    34→func (r *Registry) Execute(ctx context.Context, name string, input string) (string, error) {\n    35→\tr.mu.RLock()\n    36→\thandler, ok := r.handlers[name]\n    37→\tr.mu.RUnlock()\n    38→\tif !ok {\n    39→\t\treturn \"\", fmt.Errorf(\"activity type not registered: %s\", name)\n    40→\t}\n    41→\treturn handler(ctx, input)\n    42→}\n    43→"}]},"parent_tool_use_id":null,"session_id":"60911857-bac5-4e5c-815c-3e677cf891bd","uuid":"9f477758-330d-47b2-a5ad-f059c3157f5d","tool_use_result":{"type":"text","file":{"filePath":"/Users/michaelhabib/dev/teams-sbx/agent-orchestra/examples/miniflow/internal/activity/registry.go","content":"package activity\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n)\n\n// HandlerFunc is the signature for activity handlers.\ntype HandlerFunc func(ctx context.Context, input string) (string, error)\n\n// Registry holds registered activity handlers.\ntype Registry struct {\n\tmu       sync.RWMutex\n\thandlers map[string]HandlerFunc\n}\n\n// NewRegistry creates a new empty Registry.\nfunc NewRegistry() *Registry {\n\treturn &Registry{\n\t\thandlers: make(map[string]HandlerFunc),\n\t}\n}\n\n// Register adds a handler for the given activity name.\nfunc (r *Registry) Register(name string, handler HandlerFunc) {\n\tr.mu.Lock()\n\tdefer r.mu.Unlock()\n\tr.handlers[name] = handler\n}\n\n// Execute runs the handler registered under the given name.\n// It returns an error if no handler is registered for that name.\nfunc (r *Registry) Execute(ctx context.Context, name string, input string) (string, error) {\n\tr.mu.RLock()\n\thandler, ok := r.handlers[name]\n\tr.mu.RUnlock()\n\tif !ok {\n\t\treturn \"\", fmt.Errorf(\"activity type not registered: %s\", name)\n\t}\n\treturn handler(ctx, input)\n}\n","numLines":43,"startLine":1,"totalLines":43}}}
